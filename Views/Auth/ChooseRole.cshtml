@{
    ViewData["Title"] = "Choose Your Role";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    canvas#roleCanvas {
        position:fixed;inset:0;width:100%;height:100%;
        pointer-events:none;z-index:0;
    }

    .role-card-page {
        position:relative;z-index:10;
        background:rgba(10,10,32,0.88);
        border:1px solid rgba(108,110,245,0.22);
        border-radius:28px;
        padding:2.6rem 2.2rem;
        width:100%;max-width:480px;
        margin:auto;
        backdrop-filter:blur(20px);
        box-shadow:0 8px 48px rgba(108,110,245,0.2),
                   inset 0 1px 0 rgba(255,255,255,0.05);
        animation:cardEntry .6s cubic-bezier(.22,1,.36,1) both;
        display:flex;flex-direction:column;align-items:center;gap:0;
    }

    body.light-mode .role-card-page {
        background:rgba(255,255,255,0.93);
        border-color:rgba(75,77,224,0.16);
    }

    @@keyframes cardEntry {
        from{opacity:0;transform:translateY(32px) scale(.97)}
        to{opacity:1;transform:translateY(0) scale(1)}
    }

    .page-badge {
        display:inline-flex;align-items:center;gap:7px;
        padding:4px 13px;border-radius:20px;
        background:rgba(108,110,245,0.12);
        border:1px solid rgba(108,110,245,0.28);
        font-size:11.5px;font-weight:700;color:#6c6ef5;
        letter-spacing:.8px;text-transform:uppercase;
        margin-bottom:1.2rem;
    }

    .page-badge::before {
        content:'';width:7px;height:7px;border-radius:50%;
        background:#23e8c8;box-shadow:0 0 8px #23e8c8;
        animation:dotBlink 1.3s ease-in-out infinite;
    }

    @@keyframes dotBlink {
        0%,100%{opacity:1;transform:scale(1)}
        50%{opacity:.3;transform:scale(.6)}
    }

    .page-title {
        font-size:1.9rem;font-weight:900;
        letter-spacing:-.5px;color:#e8e8ff;
        margin-bottom:.5rem;text-align:center;
    }

    body.light-mode .page-title{color:#0a0a2e;}

    .page-sub {
        font-size:13.5px;color:#6060a0;
        margin-bottom:2rem;text-align:center;line-height:1.6;
    }

    body.light-mode .page-sub{color:#5555aa;}

    /* ── ROLE OPTION CARDS ── */
    .role-options {
        display:flex;flex-direction:column;
        gap:14px;width:100%;margin-bottom:1.6rem;
    }

    .role-option {
        display:flex;align-items:center;gap:16px;
        padding:18px 20px;
        background:rgba(255,255,255,0.04);
        border:1.5px solid rgba(108,110,245,0.18);
        border-radius:18px;
        cursor:pointer;
        transition:all .25s;
        text-decoration:none;
        color:inherit;
        position:relative;
        overflow:hidden;
    }

    body.light-mode .role-option{background:rgba(0,0,40,0.04);}

    .role-option::before {
        content:'';
        position:absolute;inset:0;
        background:linear-gradient(135deg,rgba(108,110,245,0.08),transparent);
        opacity:0;transition:opacity .3s;
        border-radius:18px;
    }

    .role-option:hover {
        transform:translateX(6px) translateY(-2px);
        border-color:rgba(108,110,245,0.5);
        box-shadow:0 8px 28px rgba(108,110,245,0.15);
    }

    .role-option:hover::before{opacity:1;}

    .role-option.student-opt:hover{border-color:rgba(108,110,245,0.6);}
    .role-option.company-opt:hover{border-color:rgba(245,166,35,0.6);}
    .role-option.admin-opt:hover  {border-color:rgba(35,232,200,0.6);}

    .role-option-icon {
        width:56px;height:56px;border-radius:16px;
        display:flex;align-items:center;justify-content:center;
        font-size:1.8rem;flex-shrink:0;
    }

    .student-icon{background:rgba(108,110,245,0.15);border:1px solid rgba(108,110,245,0.3);}
    .company-icon{background:rgba(245,166,35,0.12); border:1px solid rgba(245,166,35,0.3);}
    .admin-icon  {background:rgba(35,232,200,0.1);  border:1px solid rgba(35,232,200,0.3);}

    .role-option-info{flex:1;}

    .role-option-name {
        font-size:1rem;font-weight:800;color:#e8e8ff;
        margin-bottom:3px;
    }

    body.light-mode .role-option-name{color:#0a0a2e;}

    .role-option-desc{font-size:12.5px;color:#6060a0;line-height:1.5;}
    body.light-mode .role-option-desc{color:#5555aa;}

    .role-option-arrow {
        font-size:1.3rem;color:#4040a0;
        transition:transform .25s;
        flex-shrink:0;
    }

    .role-option:hover .role-option-arrow{
        transform:translateX(4px);
        color:#6c6ef5;
    }

    /* Back link */
    .back-link {
        font-size:13px;color:#4040a0;text-decoration:none;
        display:flex;align-items:center;gap:6px;
        transition:color .2s;
        margin-top:.4rem;
    }

    .back-link:hover{color:#6c6ef5;}

    .mtrail{
        position:fixed;width:5px;height:5px;border-radius:50%;
        pointer-events:none;z-index:9999;transform:translate(-50%,-50%);
        opacity:.8;transition:opacity .6s;
    }
</style>

<canvas id="roleCanvas"></canvas>

<div class="role-card-page">

    <p class="page-badge">Start Journey</p>
    <h2 class="page-title">Who are you?</h2>
    <p class="page-sub">Choose your role to get started with AspiraHub</p>

    <div class="role-options">

        <!-- Student -->
        <a href="/Auth/Step1" class="role-option student-opt"
           id="opt-student">
            <div class="role-option-icon student-icon">🎓</div>
            <div class="role-option-info">
                <div class="role-option-name">Student</div>
                <div class="role-option-desc">
                    Explore careers, build roadmaps, find jobs matched to your skills
                </div>
            </div>
            <div class="role-option-arrow">›</div>
        </a>

        <!-- Company -->
        <a href="/Auth/CompanyRegister" class="role-option company-opt"
           id="opt-company">
            <div class="role-option-icon company-icon">🏢</div>
            <div class="role-option-info">
                <div class="role-option-name">Company</div>
                <div class="role-option-desc">
                    Post jobs, find skill-matched candidates, track applications
                </div>
            </div>
            <div class="role-option-arrow">›</div>
        </a>

        <!-- Admin -->
        <a href="/Auth/AdminLogin" class="role-option admin-opt"
           id="opt-admin">
            <div class="role-option-icon admin-icon">⚙️</div>
            <div class="role-option-info">
                <div class="role-option-name">Admin</div>
                <div class="role-option-desc">
                    Manage platform, users, careers, skills and analytics
                </div>
            </div>
            <div class="role-option-arrow">›</div>
        </a>

    </div>

    <a href="/Auth/Index" class="back-link">← Back to Welcome</a>
</div>

<script>
(function(){
    var cv=document.getElementById('roleCanvas');
    var ctx=cv.getContext('2d');
    var W,H,mx=innerWidth/2,my=innerHeight/2,tick=0;
    var isDark=!document.body.classList.contains('light-mode');

    function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
    resize();window.addEventListener('resize',resize);
    document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;});

    var themeBtn=document.querySelector('.theme-toggle');
    if(themeBtn)themeBtn.addEventListener('click',function(){
        setTimeout(function(){isDark=!document.body.classList.contains('light-mode');},50);
    });

    var parts=[];
    function spawnPart(x,y,burst,col){
        var colors=col?[col]:['#6c6ef5','#f56cc8','#f5a623','#23e8c8','#a078f0'];
        var count=burst?14:1;
        for(var i=0;i<count;i++){
            var angle=Math.random()*Math.PI*2;
            var speed=burst?(Math.random()*4+1):(Math.random()*.5+.1);
            parts.push({
                x:x||Math.random()*W,y:y||Math.random()*H,
                vx:Math.cos(angle)*speed,vy:Math.sin(angle)*speed-(burst?2:0),
                r:Math.random()*(burst?4:2)+.5,
                color:colors[Math.floor(Math.random()*colors.length)],
                life:1,decay:Math.random()*(burst?.025:.006)+.003
            });
        }
        if(parts.length>250)parts.splice(0,parts.length-250);
    }

    var nodes=[];
    function buildGrid(){
        nodes=[];
        var cs=Math.ceil(W/80)+1,rs=Math.ceil(H/80)+1;
        for(var r=0;r<rs;r++)for(var c=0;c<cs;c++)
            nodes.push({x:c*80,y:r*80,ox:c*80,oy:r*80});
    }
    buildGrid();
    window.addEventListener('resize',function(){resize();buildGrid();});

    function frame(){
        tick+=0.012;ctx.clearRect(0,0,W,H);
        var cols2=Math.ceil(W/80)+1;
        var lc=isDark?'rgba(108,110,245,0.07)':'rgba(75,77,224,0.06)';
        nodes.forEach(function(n){
            var dx=mx-n.ox,dy=my-n.oy,d=Math.sqrt(dx*dx+dy*dy),p=Math.max(0,1-d/200);
            n.x=n.ox+dx*p*0.2+Math.sin(tick+n.oy*0.03)*2.5;
            n.y=n.oy+dy*p*0.2+Math.cos(tick+n.ox*0.03)*2.5;
        });
        ctx.strokeStyle=lc;ctx.lineWidth=.5;
        nodes.forEach(function(n,i){
            var c=i%cols2;
            if(c<cols2-1&&nodes[i+1]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+1].x,nodes[i+1].y);ctx.stroke();}
            if(nodes[i+cols2]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+cols2].x,nodes[i+cols2].y);ctx.stroke();}
        });
        nodes.forEach(function(n){
            var dx=mx-n.x,dy=my-n.y,d=Math.sqrt(dx*dx+dy*dy);
            if(d<130){
                ctx.beginPath();ctx.arc(n.x,n.y,2.5,0,6.28);
                ctx.fillStyle=isDark?'rgba(108,110,245,'+(1-d/130)*.85+')':'rgba(75,77,224,'+(1-d/130)*.7+')';
                ctx.fill();
            }
        });
        if(Math.random()<.25)spawnPart();
        parts.forEach(function(p){
            p.x+=p.vx;p.y+=p.vy;p.life-=p.decay;
            ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,6.28);
            ctx.fillStyle=p.color;ctx.globalAlpha=p.life*.5;ctx.fill();
        });
        ctx.globalAlpha=1;
        parts=parts.filter(function(p){return p.life>0;});
        requestAnimationFrame(frame);
    }
    frame();

    // Role hover effects
    var roleColors={
        'opt-student':'#6c6ef5',
        'opt-company':'#f5a623',
        'opt-admin':'#23e8c8'
    };
    Object.keys(roleColors).forEach(function(id){
        var el=document.getElementById(id);
        if(!el)return;
        el.addEventListener('mouseenter',function(){
            var r=el.getBoundingClientRect();
            spawnPart(r.left+r.width/2,r.top+r.height/2,true,roleColors[id]);
        });
    });

    var tColors=['#6c6ef5','#f56cc8','#23e8c8','#f5a623','#a078f0'];
    var lastT=0;
    document.addEventListener('mousemove',function(e){
        var now=Date.now();if(now-lastT<30)return;lastT=now;
        var d=document.createElement('div');d.className='mtrail';
        d.style.left=e.clientX+'px';d.style.top=e.clientY+'px';
        var col=tColors[Math.floor(Math.random()*5)];
        d.style.background=col;d.style.boxShadow='0 0 8px '+col;
        document.body.appendChild(d);
        setTimeout(function(){d.style.opacity='0';setTimeout(function(){if(d.parentNode)d.remove();},600);},45);
    });
})();
</script>