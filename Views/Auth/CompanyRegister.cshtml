@model AspiraHub.ViewModels.RegisterVM
@{
    ViewData["Title"] = "Company Registration";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    bool registered = ViewBag.Registered == true;
}

<style>
    canvas#compCanvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .auth-card {
        position: relative;
        z-index: 10;
        background: rgba(10,10,32,0.88);
        border: 1px solid rgba(245,166,35,0.22);
        border-radius: 24px;
        padding: 2.4rem 2.2rem;
        width: 100%;
        max-width: 440px;
        margin: auto;
        backdrop-filter: blur(20px);
        box-shadow: 0 8px 48px rgba(245,166,35,0.15), inset 0 1px 0 rgba(255,255,255,0.05);
        animation: cardEntry .6s cubic-bezier(.22,1,.36,1) both;
    }

    body.light-mode .auth-card {
        background: rgba(255,255,255,0.93);
        border-color: rgba(245,166,35,0.25);
    }

    @@keyframes cardEntry {
        from {
            opacity: 0;
            transform: translateY(32px) scale(.97)
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1)
        }
    }

    .step-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 4px 13px;
        border-radius: 20px;
        background: rgba(245,166,35,0.12);
        border: 1px solid rgba(245,166,35,0.3);
        font-size: 11.5px;
        font-weight: 700;
        color: #f5a623;
        letter-spacing: .8px;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

        .step-badge::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #f5a623;
            box-shadow: 0 0 8px #f5a623;
            animation: dotBlink 1.3s ease-in-out infinite;
        }

    @@keyframes dotBlink {
        0%, 100% {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: .3;
            transform: scale(.6)
        }
    }

    .onboard-title {
        font-size: 1.75rem;
        font-weight: 900;
        letter-spacing: -.5px;
        color: #e8e8ff;
        margin-bottom: .4rem;
    }

    body.light-mode .onboard-title {
        color: #0a0a2e;
    }

    .onboard-sub {
        font-size: 13.5px;
        color: #6060a0;
        margin-bottom: 1.6rem;
        line-height: 1.6;
    }

    body.light-mode .onboard-sub {
        color: #5555aa;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .field-wrap {
        display: flex;
        flex-direction: column;
        margin-bottom: 14px;
        width: 100%;
    }

    .field-group {
        display: flex;
        align-items: center;
        width: 100%;
        background: rgba(255,255,255,0.05);
        border: 1.5px solid rgba(245,166,35,0.2);
        border-radius: 14px;
        overflow: hidden;
        transition: border-color .25s,box-shadow .25s,transform .2s;
        min-height: 52px;
    }

    body.light-mode .field-group {
        background: rgba(0,0,40,0.04);
    }

    .field-group:focus-within {
        border-color: rgba(245,166,35,0.7);
        box-shadow: 0 0 0 3px rgba(245,166,35,0.12), 0 4px 16px rgba(245,166,35,0.15);
        transform: translateY(-1px);
    }

    .field-icon {
        width: 46px;
        min-width: 46px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
        opacity: .75;
    }

    .field-input {
        flex: 1;
        min-width: 0;
        width: 100%;
        background: transparent !important;
        border: none !important;
        outline: none !important;
        padding: .85rem .5rem .85rem 0;
        font-size: 14.5px;
        color: #e8e8ff;
        font-family: 'Segoe UI',system-ui,sans-serif;
        -webkit-appearance: none;
        appearance: none;
        box-shadow: none !important;
    }

    body.light-mode .field-input {
        color: #0a0a2e;
    }

    .field-input::placeholder {
        color: #4a4a80;
        opacity: 1;
    }

    body.light-mode .field-input::placeholder {
        color: #9090bb;
    }

    .field-input:-webkit-autofill,
    .field-input:-webkit-autofill:hover,
    .field-input:-webkit-autofill:focus {
        -webkit-text-fill-color: #e8e8ff;
        -webkit-box-shadow: 0 0 0px 1000px rgba(10,10,32,0.9) inset !important;
        transition: background-color 5000s ease-in-out 0s;
    }

    body.light-mode .field-input:-webkit-autofill {
        -webkit-text-fill-color: #0a0a2e;
        -webkit-box-shadow: 0 0 0px 1000px rgba(255,255,255,0.9) inset !important;
    }

    .eye-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0 14px;
        font-size: 16px;
        opacity: .7;
        transition: opacity .2s,transform .2s;
        flex-shrink: 0;
        height: 100%;
        display: flex;
        align-items: center;
    }

        .eye-btn:hover {
            opacity: 1;
            transform: scale(1.15);
        }

    .field-error {
        display: block;
        font-size: 12px;
        color: #f05858;
        padding: 4px 4px 0;
    }

        .field-error:empty {
            display: none;
        }

    .validation-summary-errors {
        background: rgba(245,80,80,0.1);
        border: 1px solid rgba(245,80,80,0.3);
        border-radius: 10px;
        padding: 10px 14px;
        margin-bottom: 14px;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding: 0 0 0 16px;
            color: #f05858;
            font-size: 13px;
        }

    .form-progress {
        height: 3px;
        background: rgba(245,166,35,0.12);
        border-radius: 2px;
        margin-bottom: 1.2rem;
        overflow: hidden;
    }

    .form-progress-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg,#f5a623,#f56cc8);
        border-radius: 2px;
        transition: width .4s cubic-bezier(.22,1,.36,1);
        box-shadow: 0 0 8px rgba(245,166,35,0.5);
    }

    .btn-primary {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px;
        border-radius: 50px;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: .5px;
        background: linear-gradient(135deg,#f5a623,#f056c8,#8840e0);
        color: #fff;
        border: none;
        cursor: pointer;
        box-shadow: 0 6px 28px rgba(245,166,35,0.4);
        transition: transform .25s,box-shadow .25s,filter .2s;
        position: relative;
        overflow: hidden;
        width: 100%;
        text-decoration: none;
        margin-top: 6px;
    }

        .btn-primary::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(255,255,255,0.14),transparent 55%);
            border-radius: 50px;
        }

        .btn-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 12px 38px rgba(245,166,35,0.5);
            filter: brightness(1.08);
        }

    .divider-line {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #4040a0;
        font-size: 12px;
        margin: 1rem 0;
        width: 100%;
    }

        .divider-line::before, .divider-line::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(108,110,245,0.15);
        }

    .btn-unlock-company {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 13px;
        border-radius: 50px;
        font-size: 14.5px;
        font-weight: 700;
        color: #e8e8ff;
        background: transparent;
        border: 1.5px solid rgba(245,166,35,0.3);
        cursor: pointer;
        transition: all .25s;
        text-decoration: none;
        width: 100%;
    }

    body.light-mode .btn-unlock-company {
        color: #0a0a2e;
    }

    .btn-unlock-company:hover {
        background: rgba(245,166,35,0.08);
        border-color: rgba(245,166,35,0.6);
        transform: translateY(-2px);
    }

    .auth-switch {
        text-align: center;
        margin-top: 1rem;
        font-size: 13.5px;
        color: #6060a0;
    }

    body.light-mode .auth-switch {
        color: #5555aa;
    }

    .link-blue {
        color: #f5a623;
        font-weight: 700;
        text-decoration: none;
        transition: color .2s;
    }

        .link-blue:hover {
            color: #f56cc8;
        }

    /* Success state */
    .success-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.2rem;
        text-align: center;
        animation: successEntry .7s cubic-bezier(.22,1,.36,1) both;
    }

    @@keyframes successEntry {
        from {
            opacity: 0;
            transform: scale(.9)
        }

        to {
            opacity: 1;
            transform: scale(1)
        }
    }

    .success-icon {
        font-size: 4rem;
        animation: iconBounce .7s cubic-bezier(.22,1,.36,1) both;
        animation-delay: .2s;
    }

    @@keyframes iconBounce {
        from {
            opacity: 0;
            transform: scale(.4) rotate(-20deg)
        }

        to {
            opacity: 1;
            transform: scale(1) rotate(0deg)
        }
    }

    .toast {
        position: fixed;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: rgba(10,10,32,0.95);
        border: 1px solid rgba(245,166,35,0.35);
        color: #e8e8ff;
        padding: 12px 22px;
        border-radius: 40px;
        font-size: 13.5px;
        font-weight: 600;
        box-shadow: 0 8px 28px rgba(245,166,35,0.25);
        backdrop-filter: blur(16px);
        z-index: 9999;
        animation: toastIn .4s cubic-bezier(.22,1,.36,1) forwards;
        white-space: nowrap;
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateX(-50%) translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateX(-50%) translateY(0)
        }
    }

    .mtrail {
        position: fixed;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%,-50%);
        opacity: .8;
        transition: opacity .6s;
    }
</style>

<canvas id="compCanvas"></canvas>

@if (!registered)
{
    <div class="auth-card">
        <p class="step-badge">🏢 Company</p>
        <h2 class="onboard-title">Join as Company</h2>
        <p class="onboard-sub">Post jobs and find the perfect candidates for your team.</p>

        <div class="form-progress">
            <div class="form-progress-fill" id="progressFill"></div>
        </div>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form asp-action="CompanyRegister" method="post" class="auth-form" id="compForm">
            @Html.AntiForgeryToken()
            <input asp-for="Role" type="hidden" value="Company" />

            <div class="field-wrap">
                <div class="field-group">
                    <div class="field-icon">🏢</div>
                    <input asp-for="FullName" class="field-input"
                           placeholder="Company Name"
                           autocomplete="organization"
                           oninput="updateProgress()" />
                </div>
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <div class="field-wrap">
                <div class="field-group">
                    <div class="field-icon">✉️</div>
                    <input asp-for="Email" class="field-input"
                           placeholder="Company Email"
                           autocomplete="email"
                           oninput="updateProgress()" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="field-wrap">
                <div class="field-group">
                    <div class="field-icon">🔒</div>
                    <input asp-for="Password" type="password" id="compPass"
                           class="field-input" placeholder="Password"
                           autocomplete="new-password"
                           oninput="updateProgress()" />
                    <button type="button" class="eye-btn"
                            onclick="toggleEye('compPass','eyeComp')">
                        <span id="eyeComp">👁️</span>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="field-wrap">
                <div class="field-group">
                    <div class="field-icon">🔒</div>
                    <input asp-for="ConfirmPassword" type="password" id="compPass2"
                           class="field-input" placeholder="Confirm Password"
                           autocomplete="new-password"
                           oninput="updateProgress()" />
                    <button type="button" class="eye-btn"
                            onclick="toggleEye('compPass2','eyeComp2')">
                        <span id="eyeComp2">👁️</span>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-primary">
                🏢 Create Company Account
            </button>
        </form>

        <div class="divider-line">OR</div>

        <a href="/Auth/Login" class="btn-unlock-company">
            🔓 Already have an account? Login
        </a>

        <p class="auth-switch">
            <a href="/Auth/ChooseRole" class="link-blue">← Choose different role</a>
        </p>
    </div>
}
else
{
    <div class="auth-card">
        <div class="success-wrap">
            <div class="success-icon">🎉</div>
            <h2 class="onboard-title">Welcome, @Model.FullName!</h2>
            <p class="onboard-sub">
                Your company account is ready.<br>
                Start posting jobs and finding talent!
            </p>
            <a href="/CompanyDashboard/Index" class="btn-primary">
                Go to Dashboard →
            </a>
        </div>
    </div>
}

<script>
    (function(){
        var cv=document.getElementById('compCanvas');
        var ctx=cv.getContext('2d');
        var W,H,mx=innerWidth/2,my=innerHeight/2,tick=0;
        var isDark=!document.body.classList.contains('light-mode');
        function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
        resize();window.addEventListener('resize',resize);
        document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;});

        var themeBtn=document.querySelector('.theme-toggle');
        if(themeBtn)themeBtn.addEventListener('click',function(){setTimeout(function(){isDark=!document.body.classList.contains('light-mode');},50);});

        var parts=[];
        function sp(x,y,burst){
            var colors=['#f5a623','#f56cc8','#6c6ef5','#23e8c8'];
            var count=burst?12:1;
            for(var i=0;i<count;i++){
                var angle=Math.random()*Math.PI*2,speed=burst?(Math.random()*4+1):(Math.random()*.5+.1);
                parts.push({x:x||Math.random()*W,y:y||Math.random()*H,vx:Math.cos(angle)*speed,vy:Math.sin(angle)*speed-(burst?2:0),r:Math.random()*(burst?4:2)+.5,color:colors[Math.floor(Math.random()*colors.length)],life:1,decay:Math.random()*(burst?.025:.006)+.003});
            }
            if(parts.length>200)parts.splice(0,parts.length-200);
        }

        var nodes=[];
        function buildGrid(){nodes=[];var cs=Math.ceil(W/80)+1,rs=Math.ceil(H/80)+1;for(var r=0;r<rs;r++)for(var c=0;c<cs;c++)nodes.push({x:c*80,y:r*80,ox:c*80,oy:r*80});}
        buildGrid();window.addEventListener('resize',function(){resize();buildGrid();});

        function frame(){
            tick+=0.012;ctx.clearRect(0,0,W,H);
            var cols2=Math.ceil(W/80)+1;
            var lc=isDark?'rgba(245,166,35,0.06)':'rgba(245,166,35,0.05)';
            nodes.forEach(function(n){var dx=mx-n.ox,dy=my-n.oy,d=Math.sqrt(dx*dx+dy*dy),p=Math.max(0,1-d/200);n.x=n.ox+dx*p*0.2+Math.sin(tick+n.oy*0.03)*2.5;n.y=n.oy+dy*p*0.2+Math.cos(tick+n.ox*0.03)*2.5;});
            ctx.strokeStyle=lc;ctx.lineWidth=.5;
            nodes.forEach(function(n,i){var c=i%cols2;if(c<cols2-1&&nodes[i+1]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+1].x,nodes[i+1].y);ctx.stroke();}if(nodes[i+cols2]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+cols2].x,nodes[i+cols2].y);ctx.stroke();}});
            nodes.forEach(function(n){var dx=mx-n.x,dy=my-n.y,d=Math.sqrt(dx*dx+dy*dy);if(d<130){ctx.beginPath();ctx.arc(n.x,n.y,2.5,0,6.28);ctx.fillStyle='rgba(245,166,35,'+(1-d/130)*.7+')';ctx.fill();}});
            if(Math.random()<.25)sp();
            parts.forEach(function(p){p.x+=p.vx;p.y+=p.vy;p.life-=p.decay;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,6.28);ctx.fillStyle=p.color;ctx.globalAlpha=p.life*.5;ctx.fill();});
            ctx.globalAlpha=1;parts=parts.filter(function(p){return p.life>0;});
            requestAnimationFrame(frame);
        }
        frame();

        var fields=['FullName','Email','Password','ConfirmPassword'];
        window.updateProgress=function(){
            var filled=0;
            fields.forEach(function(f){var el=document.querySelector('[name="'+f+'"]');if(el&&el.value.trim().length>0)filled++;});
            var fill=document.getElementById('progressFill');
            if(fill)fill.style.width=((filled/fields.length)*100)+'%';
        };

        window.toggleEye=function(inputId,eyeId){
            var input=document.getElementById(inputId),eye=document.getElementById(eyeId);
            if(!input||!eye)return;
            input.type=input.type==='password'?'text':'password';
            eye.textContent=input.type==='password'?'👁️':'🙈';
        };

        var tColors=['#f5a623','#f56cc8','#6c6ef5','#23e8c8'];
        var lastT=0;
        document.addEventListener('mousemove',function(e){
            var now=Date.now();if(now-lastT<30)return;lastT=now;
            var d=document.createElement('div');d.className='mtrail';
            d.style.left=e.clientX+'px';d.style.top=e.clientY+'px';
            var col=tColors[Math.floor(Math.random()*tColors.length)];
            d.style.background=col;d.style.boxShadow='0 0 8px '+col;
            document.body.appendChild(d);
            setTimeout(function(){d.style.opacity='0';setTimeout(function(){if(d.parentNode)d.remove();},600);},45);
        });
    })();
</script>