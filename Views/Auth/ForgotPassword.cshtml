@model AspiraHub.ViewModels.ForgotPasswordVM
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    int step = Model?.Step ?? 1;
}

<div class="auth-card">

    <div class="auth-card-header">
        <div class="auth-icon-wrap" style="font-size:2.5rem">🔐</div>
        <div class="accent-line"></div>
        <h2 class="auth-card-title">Reset Password</h2>
        <p class="auth-card-sub">
            @(step == 1 ? "Enter your email to receive an OTP"
              : step == 2 ? "Enter the OTP sent to your email"
              : "Choose a new password")
        </p>
    </div>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-error">@ViewBag.Message</div>
    }
    @if (ViewBag.Success == true && step == 2)
    {
        <div class="alert alert-success">✅ OTP sent. Check your inbox (and spam folder).</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-error">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    @if (step == 1)
    {
        <form asp-action="ForgotPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div class="field-group">
                <div class="field-icon">✉️</div>
                <input type="email" name="Email" class="field-input"
                       placeholder="Your registered email" required />
            </div>
            <button type="submit" class="btn btn-primary btn-full">Send OTP 📧</button>
        </form>
    }
    else if (step == 2)
    {
        <form asp-action="VerifyOtp" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Email" value="@Model.Email" />
            <div class="field-group">
                <div class="field-icon">🔢</div>
                <input type="text" name="OtpCode" class="field-input"
                       placeholder="6-digit OTP" maxlength="6" required />
            </div>
            <button type="submit" class="btn btn-primary btn-full">Verify OTP ✅</button>
        </form>
        <form asp-action="ForgotPassword" method="post" style="margin-top:8px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Email" value="@Model.Email" />
            <button type="submit" class="btn btn-outline btn-full">Resend OTP</button>
        </form>
    }
    else if (step == 3)
    {
        <form asp-action="ResetPassword" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Email" value="@Model.Email" />
            <input type="hidden" name="OtpCode" value="@Model.OtpCode" />
            <div class="field-group">
                <div class="field-icon">🔒</div>
                <input type="password" name="NewPassword" class="field-input"
                       placeholder="New password" required minlength="8" />
            </div>
            <div class="field-group">
                <div class="field-icon">🔒</div>
                <input type="password" name="ConfirmNewPassword" class="field-input"
                       placeholder="Confirm new password" required minlength="8" />
            </div>
            <button type="submit" class="btn btn-primary btn-full">Reset Password 🔁</button>
        </form>
    }

    <a asp-action="Login" class="btn btn-outline btn-full" style="margin-top:10px">
        ← Back to Login
    </a>
</div>
