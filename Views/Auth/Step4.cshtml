@model AspiraHub.ViewModels.OnboardingStep4VM
@{
    ViewData["Title"] = "Your Interests";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    canvas#stepBg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .floaters {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
    }

    .floater {
        position: absolute;
        opacity: 0;
        animation: floatUp linear infinite;
        user-select: none;
    }

    @@keyframes floatUp {
        0% {
            opacity: 0;
            transform: translateY(100vh) rotate(0deg) scale(0.7);
        }

        10% {
            opacity: .7;
        }

        80% {
            opacity: .4;
        }

        100% {
            opacity: 0;
            transform: translateY(-10vh) rotate(340deg) scale(1.1);
        }
    }

    .orbit-tr {
        position: fixed;
        top: -90px;
        right: -90px;
        width: 340px;
        height: 340px;
        pointer-events: none;
        z-index: 1;
        animation: spinS 22s linear infinite;
    }

    .orbit-bl {
        position: fixed;
        bottom: -70px;
        left: -70px;
        width: 280px;
        height: 280px;
        pointer-events: none;
        z-index: 1;
        animation: spinS 28s linear infinite reverse;
    }

    @@keyframes spinS {
        to {
            transform: rotate(360deg);
        }
    }

    .edu-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        overflow: hidden;
        height: 34px;
        background: rgba(245,108,200,0.06);
        border-top: 1px solid rgba(245,108,200,0.12);
        z-index: 2;
        pointer-events: none;
    }

    .banner-track {
        display: inline-flex;
        gap: 2.5rem;
        white-space: nowrap;
        animation: marquee 24s linear infinite;
        padding-top: 7px;
        font-size: 12.5px;
        color: rgba(245,108,200,0.55);
    }

    @@keyframes marquee {
        from {
            transform: translateX(0)
        }

        to {
            transform: translateX(-50%);
        }
    }

    .particle {
        position: fixed;
        pointer-events: none;
        z-index: 1;
        border-radius: 50%;
        animation: pFloat linear infinite;
    }

    @@keyframes pFloat {
        0% {
            transform: translateY(100vh) scale(0);
            opacity: 0;
        }

        15% {
            opacity: .5;
        }

        85% {
            opacity: .2;
        }

        100% {
            transform: translateY(-8vh) scale(1);
            opacity: 0;
        }
    }

    /* CARD */
    .onboarding-card {
        position: relative;
        z-index: 5;
        background: rgba(10,10,30,0.83);
        backdrop-filter: blur(22px);
        border: 1px solid rgba(245,108,200,0.22);
        border-radius: 26px;
        padding: 2.4rem 2.2rem 2rem;
        max-width: 500px;
        width: 100%;
        margin: auto;
        box-shadow: 0 8px 48px rgba(245,108,200,0.1),0 0 0 1px rgba(255,255,255,0.04);
        animation: cardIn .65s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(32px) scale(0.96);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* Progress */
    .step-prog {
        display: flex;
        gap: 6px;
        margin-bottom: 1.4rem;
        animation: fadeUp .4s .05s both;
    }

    .prog-dot {
        height: 5px;
        border-radius: 4px;
        flex: 1;
        background: rgba(108,110,245,0.15);
    }

        .prog-dot.done {
            background: #6c6ef5;
        }

        .prog-dot.active {
            background: linear-gradient(90deg,#f56cc8,#a078f0);
        }

    /* Badge */
    .step-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(245,108,200,0.1);
        border: 1px solid rgba(245,108,200,0.28);
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 12px;
        color: #f56cc8;
        margin-bottom: .75rem;
        animation: fadeUp .4s .1s both;
    }

    .onboard-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #e8e8ff;
        margin-bottom: 1.5rem;
        line-height: 1.3;
        animation: fadeUp .4s .18s both;
    }

        .onboard-title span {
            color: #f56cc8;
        }

    /* TAG GRID */
    .tag-group {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 10px;
        margin-bottom: 1.2rem;
        animation: fadeUp .45s .22s both;
    }

    .tag-pill {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 14px 10px;
        border-radius: 16px;
        border: 1.5px solid rgba(245,108,200,0.2);
        background: rgba(20,18,55,0.55);
        cursor: pointer;
        transition: border-color .25s,background .25s,transform .22s,box-shadow .25s;
        overflow: hidden;
        text-align: center;
        user-select: none;
    }

        /* shimmer */
        .tag-pill::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(110deg,transparent 25%,rgba(245,108,200,0.1) 50%,transparent 75%);
            transform: translateX(-100%);
            transition: transform .5s;
        }

        .tag-pill:hover::before {
            transform: translateX(100%);
        }

        .tag-pill:hover {
            border-color: rgba(245,108,200,0.5);
            background: rgba(245,108,200,0.08);
            transform: translateY(-4px) scale(1.03);
            box-shadow: 0 6px 22px rgba(245,108,200,0.2);
        }

        .tag-pill:has(input:checked) {
            border-color: #f56cc8;
            background: rgba(245,108,200,0.16);
            transform: translateY(-4px) scale(1.03);
            box-shadow: 0 0 0 3px rgba(245,108,200,0.2),0 6px 24px rgba(245,108,200,0.25);
        }

        .tag-pill input[type="checkbox"] {
            display: none;
        }

        .tag-pill span {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 600;
            color: #e8e8ff;
            pointer-events: none;
            position: relative;
            z-index: 1;
            line-height: 1.3;
        }

            /* emoji big */
            .tag-pill span::first-line {
                font-size: 1.6rem;
            }

        /* Selected checkmark */
        .tag-pill:has(input:checked)::after {
            content: '✓';
            position: absolute;
            top: 7px;
            right: 10px;
            font-size: 11px;
            font-weight: 700;
            color: #f56cc8;
            background: rgba(245,108,200,0.15);
            border-radius: 50%;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 18px;
            text-align: center;
        }

        /* stagger tag animations */
        .tag-pill:nth-child(1) {
            animation: fadeUp .4s .25s both;
        }

        .tag-pill:nth-child(2) {
            animation: fadeUp .4s .3s both;
        }

        .tag-pill:nth-child(3) {
            animation: fadeUp .4s .35s both;
        }

        .tag-pill:nth-child(4) {
            animation: fadeUp .4s .4s both;
        }

        .tag-pill:nth-child(5) {
            animation: fadeUp .4s .45s both;
        }

        .tag-pill:nth-child(6) {
            animation: fadeUp .4s .5s both;
        }

    /* Custom input */
    .field-group {
        position: relative;
        margin-bottom: 1.1rem;
        animation: fadeUp .45s .52s both;
    }

    .field-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.1rem;
        pointer-events: none;
        transition: transform .3s;
        z-index: 2;
    }

    .field-group:focus-within .field-icon {
        transform: translateY(-50%) scale(1.2) rotate(-8deg);
    }

    .field-input {
        width: 100%;
        padding: 12px 12px 12px 42px;
        border-radius: 13px;
        border: 1.5px solid rgba(245,108,200,0.18);
        background: rgba(20,18,50,0.6);
        color: #e8e8ff;
        font-size: 14px;
        outline: none;
        transition: border-color .25s,box-shadow .25s,background .25s;
    }

        .field-input::placeholder {
            color: rgba(168,158,248,0.4);
        }

        .field-input:focus {
            border-color: #f56cc8;
            background: rgba(30,26,60,0.7);
            box-shadow: 0 0 0 3px rgba(245,108,200,0.15),0 4px 18px rgba(245,108,200,0.1);
        }

    /* Selected count badge */
    .selected-count {
        font-size: 12px;
        color: rgba(245,108,200,0.7);
        text-align: right;
        margin-bottom: .5rem;
        animation: fadeUp .4s .2s both;
        min-height: 1.2em;
        transition: color .2s;
    }

        .selected-count.has-sel {
            color: #f56cc8;
        }

    /* Button */
    .btn-full {
        width: 100%;
        padding: 13px;
        border-radius: 40px;
        border: none;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        background: linear-gradient(135deg,#f56cc8,#a078f0);
        color: #fff;
        box-shadow: 0 4px 22px rgba(245,108,200,0.35);
        transition: transform .2s,box-shadow .2s;
        position: relative;
        overflow: hidden;
        animation: fadeUp .45s .58s both;
        margin-top: .4rem;
    }

        .btn-full::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(110deg,transparent 25%,rgba(255,255,255,0.15) 50%,transparent 75%);
            transform: translateX(-100%);
            transition: transform .55s;
        }

        .btn-full:hover::after {
            transform: translateX(100%);
        }

        .btn-full:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 28px rgba(245,108,200,0.45);
        }

        .btn-full:active {
            transform: scale(0.98);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes ripple {
        to {
            transform: scale(1);
            opacity: 0;
        }
    }
</style>

<canvas id="stepBg"></canvas>
<div class="floaters" id="floaters"></div>

<div class="orbit-tr">
    <svg viewBox="0 0 340 340" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="170" cy="170" r="150" stroke="rgba(245,108,200,0.1)" stroke-width="1" stroke-dasharray="7 6" />
        <circle cx="170" cy="170" r="105" stroke="rgba(160,120,240,0.08)" stroke-width="1" stroke-dasharray="4 8" />
        <circle cx="170" cy="20" r="6" fill="#f56cc8" opacity=".5" />
        <circle cx="320" cy="170" r="5" fill="#a078f0" opacity=".4" />
        <text x="158" y="28" font-size="14" opacity=".5">🎨</text>
        <text x="308" y="178" font-size="12" opacity=".4">💼</text>
    </svg>
</div>
<div class="orbit-bl">
    <svg viewBox="0 0 280 280" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="140" cy="140" r="120" stroke="rgba(245,108,200,0.08)" stroke-width="1" stroke-dasharray="5 7" />
        <circle cx="140" cy="140" r="75" stroke="rgba(160,120,240,0.07)" stroke-width="1" stroke-dasharray="3 6" />
        <circle cx="140" cy="20" r="5" fill="#f56cc8" opacity=".35" />
        <text x="128" y="28" font-size="13" opacity=".4">🎭</text>
    </svg>
</div>

<div class="edu-banner">
    <div class="banner-track" id="bannerTrack"></div>
</div>

<div class="auth-card onboarding-card">

    @Html.Partial("_StepBar", 4)

    <div class="step-prog">
        <div class="prog-dot done"></div>
        <div class="prog-dot done"></div>
        <div class="prog-dot done"></div>
        <div class="prog-dot active"></div>
        <div class="prog-dot"></div>
    </div>

    <p class="step-badge">🎨 Step 4 of 5</p>
    <h2 class="onboard-title">What are you <span>interested in?</span></h2>

    <div class="selected-count" id="selCount">Select your interests below</div>

    <form asp-action="Step4" method="post" class="auth-form">
        @Html.AntiForgeryToken()

        <div class="tag-group">
            @foreach (var (interest, icon) in new[]{
                ("Technology","💻"),("Business","💼"),("Design","🎨"),
                ("Medicine","🏥"),("Engineering","⚙️"),("Arts","🎭")
            })
            {
                <label class="tag-pill">
                    <input type="checkbox" name="Interests" value="@interest"
                           onchange="updateCount()" />
                    <span><span style="font-size:1.8rem;display:block;">@icon</span>@interest</span>
                </label>
            }
        </div>
        <div class="field-group">
            <div class="field-icon">✍️</div>
            <input asp-for="CustomInterest" class="field-input"
                   placeholder="Or write your own interest..." />
        </div>

        <button type="submit" class="btn btn-primary btn-full">Continue →</button>
    </form>
</div>

@section Scripts {
    <script>
        (function(){

        /* GRID CANVAS */
        var cv=document.getElementById('stepBg'),ctx=cv.getContext('2d');
        var W,H,mx,my,tick=0;
        function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;mx=W/2;my=H/2;}
        resize();window.addEventListener('resize',resize);
        document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;});
        var nodes=[];
        function buildGrid(){
            nodes=[];
            var cs=Math.ceil(W/68)+1,rs=Math.ceil(H/68)+1;
            for(var r=0;r<rs;r++)for(var c=0;c<cs;c++)nodes.push({ox:c*68,oy:r*68,x:c*68,y:r*68});
        }
        buildGrid();window.addEventListener('resize',buildGrid);
        function frame(){
            tick+=0.011;ctx.clearRect(0,0,W,H);
            var cols=Math.ceil(W/68)+1;
            nodes.forEach(function(n){
                var dx=mx-n.ox,dy=my-n.oy,d=Math.sqrt(dx*dx+dy*dy),p=Math.max(0,1-d/170);
                n.x=n.ox+dx*p*0.13+Math.sin(tick+n.oy*0.035)*1.6;
                n.y=n.oy+dy*p*0.13+Math.cos(tick+n.ox*0.035)*1.6;
            });
            ctx.strokeStyle='rgba(245,108,200,0.07)';ctx.lineWidth=0.65;
            nodes.forEach(function(n,i){
                var c=i%cols;
                if(c<cols-1&&nodes[i+1]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+1].x,nodes[i+1].y);ctx.stroke();}
                if(nodes[i+cols]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+cols].x,nodes[i+cols].y);ctx.stroke();}
            });
            nodes.forEach(function(n){
                var dx=mx-n.x,dy=my-n.y,d=Math.sqrt(dx*dx+dy*dy);
                if(d<110){ctx.beginPath();ctx.arc(n.x,n.y,2.5,0,Math.PI*2);ctx.fillStyle='rgba(245,108,200,'+(1-d/110)*0.5+')';ctx.fill();}
            });
            requestAnimationFrame(frame);
        }
        frame();

        /* FLOATING EMOJIS */
        var emojis=['💻','💼','🎨','🏥','⚙️','🎭','🌟','📱','🎯','🔬','🎵','🌍','📸','✨','🚀'];
        var fw=document.getElementById('floaters');
        for(var i=0;i<16;i++){
            var el=document.createElement('div');el.className='floater';
            el.textContent=emojis[i%emojis.length];
            el.style.left=(Math.random()*95)+'%';
            el.style.fontSize=(1+Math.random()*1.1)+'rem';
            el.style.animationDuration=(8+Math.random()*10)+'s';
            el.style.animationDelay=(-Math.random()*10)+'s';
            fw.appendChild(el);
        }

        /* BANNER */
        var items=['💻 Technology','💼 Business','🎨 Design','🏥 Medicine',
            '⚙️ Engineering','🎭 Arts','🌟 Innovation','📱 Mobile Dev',
            '🎯 Marketing','🔬 Research','🎵 Music','🌍 Environment'];
        var track=document.getElementById('bannerTrack');
        items.concat(items).concat(items).forEach(function(t){
            var sp=document.createElement('span');sp.textContent=t;track.appendChild(sp);
        });

        /* PARTICLES */
        var pc=['#f56cc8','#a078f0','#6c6ef5','#f5a623'];
        for(var j=0;j<12;j++){
            var p=document.createElement('div');p.className='particle';
            var sz=2+Math.random()*3.5;
            p.style.cssText='width:'+sz+'px;height:'+sz+'px;background:'+pc[j%4]+
                ';left:'+Math.random()*100+'%;animation-duration:'+(7+Math.random()*9)+'s'+
                ';animation-delay:'+(-Math.random()*9)+'s';
            document.body.appendChild(p);
        }

        /* TAG RIPPLE */
        var rs=document.createElement('style');
        rs.textContent='@@keyframes ripple{to{transform:scale(1);opacity:0;}}';
        document.head.appendChild(rs);

        document.querySelectorAll('.tag-pill').forEach(function(pill){
            pill.addEventListener('click',function(e){
                var rp=document.createElement('span');
                var rc=pill.getBoundingClientRect();
                var sz=Math.max(rc.width,rc.height)*2;
                rp.style.cssText='position:absolute;border-radius:50%;pointer-events:none;'+
                    'background:rgba(245,108,200,0.2);width:'+sz+'px;height:'+sz+'px;'+
                    'left:'+(e.clientX-rc.left-sz/2)+'px;top:'+(e.clientY-rc.top-sz/2)+'px;'+
                    'transform:scale(0);animation:ripple .55s ease-out forwards;';
                pill.appendChild(rp);
                setTimeout(function(){rp.remove();},580);
            });
        });

        })();

        function updateCount(){
            var checked=document.querySelectorAll('.tag-group input:checked').length;
            var el=document.getElementById('selCount');
            if(checked===0){el.textContent='Select your interests below';el.classList.remove('has-sel');}
            else{el.textContent=checked+' interest'+(checked>1?'s':'')+' selected ✓';el.classList.add('has-sel');}
        }
    </script>
}