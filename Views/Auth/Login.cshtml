@model AspiraHub.ViewModels.LoginVM
@{
    ViewData["Title"] = "Unlock Your Journey";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    canvas#bgCanvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .blob {
        position: fixed;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
        filter: blur(90px);
    }

    .blob1 {
        width: 600px;
        height: 600px;
        background: rgba(108,110,245,0.07);
        top: -180px;
        left: -180px;
        animation: blobD1 20s ease-in-out infinite;
    }

    .blob2 {
        width: 500px;
        height: 500px;
        background: rgba(245,108,200,0.05);
        bottom: -130px;
        right: -130px;
        animation: blobD2 25s ease-in-out infinite;
    }

    .blob3 {
        width: 380px;
        height: 380px;
        background: rgba(35,232,200,0.03);
        top: 40%;
        left: 45%;
        animation: blobD3 18s ease-in-out infinite;
    }

    #mouseOrb {
        position: fixed;
        width: 460px;
        height: 460px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 1;
        transform: translate(-50%,-50%);
        background: radial-gradient(circle,rgba(108,110,245,0.09) 0%,rgba(245,108,200,0.04) 45%,transparent 68%);
    }

    .stars-layer {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
    }

    .fstar {
        position: absolute;
        animation: floatStar ease-in-out infinite;
    }

    .mtrail {
        position: fixed;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%,-50%);
        opacity: .85;
        transition: opacity .6s;
    }

    .ck-spark {
        position: fixed;
        pointer-events: none;
        z-index: 9998;
        font-size: 18px;
        animation: sparkFly .8s ease forwards;
    }

    .login-layout {
        position: relative;
        z-index: 5;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4rem;
        padding: 2rem;
        font-family: 'Segoe UI',system-ui,sans-serif;
        color: #e8e8ff;
    }

    .girl-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        flex-shrink: 0;
    }

    .bubble {
        background: rgba(16,16,58,0.92);
        border: 1px solid rgba(108,110,245,0.5);
        border-radius: 16px;
        padding: 9px 16px;
        font-size: 12.5px;
        color: #e8e8ff;
        white-space: nowrap;
        margin-bottom: 12px;
        position: relative;
        animation: bubFloat 3s ease-in-out infinite;
        text-align: center;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 20px rgba(108,110,245,0.2);
    }

        .bubble::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 8px solid transparent;
            border-top-color: rgba(16,16,58,0.92);
        }

        .bubble.pop {
            animation: bubPop .3s ease both;
        }

    .girl-wrap {
        width: 200px;
        animation: girlBob 3.5s ease-in-out infinite;
        filter: drop-shadow(0 8px 28px rgba(108,110,245,0.45));
        cursor: pointer;
    }

        .girl-wrap:hover {
            filter: drop-shadow(0 8px 36px rgba(245,108,200,0.6));
        }

    .girl-svg {
        width: 100%;
        height: auto;
        display: block;
    }

    .arm-r {
        transform-origin: 108px 148px;
        animation: armWave 1.8s ease-in-out infinite;
    }

    .ahoge {
        transform-origin: 80px 44px;
        animation: ahogeW 2.5s ease-in-out infinite;
    }

    .sp {
        animation: spPop 2.2s ease-in-out infinite;
    }

    .sp1 {
        animation-delay: 0s
    }

    .sp2 {
        animation-delay: .4s
    }

    .sp3 {
        animation-delay: .8s
    }

    .sp4 {
        animation-delay: 1.2s
    }

    .auth-card {
        position: relative;
        z-index: 5;
        background: rgba(10,10,30,0.85);
        backdrop-filter: blur(24px);
        border: 1px solid rgba(108,110,245,0.25);
        border-radius: 28px;
        padding: 2.6rem 2.4rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 8px 48px rgba(108,110,245,0.18);
        animation: cardIn .65s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(28px) scale(0.96);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .auth-card-header {
        text-align: center;
        margin-bottom: 1.8rem;
        animation: fadeUp .4s .1s both;
    }

    .auth-icon-wrap {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg,#10104a,#261870);
        border: 1.5px solid rgba(108,110,245,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        box-shadow: 0 0 30px rgba(108,110,245,0.35);
        animation: iconPulse 3s ease-in-out infinite;
    }

    .header-mascot {
        width: 44px;
        height: 44px;
        object-fit: contain;
    }

    .accent-line {
        width: 48px;
        height: 3px;
        background: linear-gradient(90deg,#6c6ef5,#f56cc8);
        border-radius: 2px;
        margin: 0 auto .9rem;
    }

    .auth-card-title {
        font-size: 1.55rem;
        font-weight: 800;
        color: #e8e8ff;
        margin-bottom: .3rem;
        letter-spacing: -.5px;
    }

    .auth-card-sub {
        font-size: 13px;
        color: #8888bb;
    }

    .alert-error {
        background: rgba(245,108,200,0.1);
        border: 1px solid rgba(245,108,200,0.3);
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 13px;
        color: #f56cc8;
        margin-bottom: 1.1rem;
    }

        .alert-error:empty {
            display: none;
        }

    .field-group {
        position: relative;
        margin-bottom: 1.1rem;
        animation: fadeUp .45s both;
    }

        .field-group:nth-child(1) {
            animation-delay: .2s
        }

        .field-group:nth-child(2) {
            animation-delay: .3s
        }

    .field-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.1rem;
        pointer-events: none;
        z-index: 2;
        transition: transform .3s;
    }

    .field-group:focus-within .field-icon {
        transform: translateY(-50%) scale(1.2) rotate(-8deg);
    }

    .field-input {
        width: 100%;
        padding: 13px 44px;
        border-radius: 14px;
        border: 1.5px solid rgba(108,110,245,0.2);
        background: rgba(18,16,50,0.65);
        color: #e8e8ff;
        font-size: 14px;
        outline: none;
        transition: border-color .25s, box-shadow .25s, background .25s;
    }

        .field-input::placeholder {
            color: rgba(168,158,248,0.4);
        }

        .field-input:focus {
            border-color: #6c6ef5;
            background: rgba(28,24,64,0.75);
            box-shadow: 0 0 0 3px rgba(108,110,245,0.18);
        }

    .eye-btn {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.1rem;
        color: rgba(168,158,248,0.5);
        transition: color .2s, transform .2s;
        z-index: 2;
        padding: 2px;
    }

        .eye-btn:hover {
            color: #6c6ef5;
            transform: translateY(-50%) scale(1.15);
        }

    .field-error {
        display: block;
        font-size: 12px;
        color: #f56cc8;
        margin-top: 4px;
        min-height: 1.1em;
    }

    .field-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.2rem;
        animation: fadeUp .45s .35s both;
    }

    .checkbox-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

    .checkbox {
        width: 17px;
        height: 17px;
        border-radius: 5px;
        accent-color: #6c6ef5;
        cursor: pointer;
    }

    .checkbox-label {
        font-size: 13px;
        color: #8888bb;
    }

    .forgot-link {
        font-size: 13px;
        color: rgba(108,110,245,0.8);
        text-decoration: none;
        transition: color .2s;
    }

        .forgot-link:hover {
            color: #6c6ef5;
        }

    .btn-full {
        width: 100%;
        padding: 14px;
        border-radius: 40px;
        border: none;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        background: linear-gradient(135deg,#5a5cf5,#8840e0,#f056c8);
        color: #fff;
        letter-spacing: .4px;
        box-shadow: 0 6px 28px rgba(108,110,245,0.45);
        transition: transform .22s, box-shadow .22s;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        animation: fadeUp .45s .42s both;
    }

        .btn-full::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,rgba(255,255,255,0.14),transparent 55%);
            border-radius: 40px;
            pointer-events: none;
        }

        .btn-full:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 12px 36px rgba(245,108,200,0.55);
        }

        .btn-full:active {
            transform: scale(0.98);
        }

    .btn-icon {
        font-size: 17px;
    }

    .divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 1.4rem 0 1rem;
        color: #8888bb;
        font-size: 12px;
        animation: fadeUp .45s .48s both;
    }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(108,110,245,0.18);
        }

    .auth-switch {
        font-size: 13px;
        color: #8888bb;
        text-align: center;
        margin-bottom: .7rem;
        animation: fadeUp .45s .52s both;
    }

    .btn-outline {
        width: 100%;
        padding: 13px;
        border-radius: 40px;
        border: 1.5px solid rgba(108,110,245,0.35);
        background: transparent;
        color: #e8e8ff;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color .22s, color .22s, transform .22s, background .22s;
        animation: fadeUp .45s .56s both;
    }

        .btn-outline:hover {
            border-color: #6c6ef5;
            color: #6c6ef5;
            transform: translateY(-2px);
            background: rgba(108,110,245,0.06);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes girlBob {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-12px)
        }
    }

    @@keyframes armWave {
        0%, 100% {
            transform: rotate(0deg)
        }

        30% {
            transform: rotate(-22deg)
        }

        70% {
            transform: rotate(15deg)
        }
    }

    @@keyframes ahogeW {
        0%, 100% {
            transform: rotate(-5deg)
        }

        50% {
            transform: rotate(9deg)
        }
    }

    @@keyframes spPop {
        0%, 100% {
            opacity: .2;
            transform: scale(.8)
        }

        50% {
            opacity: 1;
            transform: scale(1.3)
        }
    }

    @@keyframes bubFloat {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-6px)
        }
    }

    @@keyframes bubPop {
        0% {
            transform: scale(1)
        }

        40% {
            transform: scale(1.16)
        }

        100% {
            transform: scale(1)
        }
    }

    @@keyframes iconPulse {
        0%, 100% {
            box-shadow: 0 0 30px rgba(108,110,245,0.35)
        }

        50% {
            box-shadow: 0 0 50px rgba(245,108,200,0.5)
        }
    }

    @@keyframes floatStar {
        0%, 100% {
            transform: translateY(0) rotate(0);
            opacity: .12
        }

        50% {
            transform: translateY(-22px) rotate(25deg);
            opacity: .55
        }
    }

    @@keyframes blobD1 {
        0%, 100% {
            transform: translate(0,0) scale(1)
        }

        50% {
            transform: translate(60px,40px) scale(1.1)
        }
    }

    @@keyframes blobD2 {
        0%, 100% {
            transform: translate(0,0) scale(1)
        }

        50% {
            transform: translate(-50px,-30px) scale(1.08)
        }
    }

    @@keyframes blobD3 {
        0%, 100% {
            transform: translate(-50%,-50%) scale(1)
        }

        50% {
            transform: translate(-50%,-50%) scale(1.15)
        }
    }

    @@keyframes sparkFly {
        0% {
            opacity: 1;
            transform: translate(-50%,-50%) scale(1)
        }

        100% {
            opacity: 0;
            transform: translate(-50%,-200%) scale(0.3)
        }
    }

    @@media(max-width:820px) {
        .login-layout {
            flex-direction: column;
            gap: 1.5rem;
            padding: 1.5rem 1rem;
        }

        .girl-side {
            order: -1;
        }

        .girl-wrap {
            width: 140px;
        }

        .auth-card {
            padding: 2rem 1.6rem;
        }
    }
</style>

<div class="blob blob1"></div>
<div class="blob blob2"></div>
<div class="blob blob3"></div>
<div id="mouseOrb"></div>
<canvas id="bgCanvas"></canvas>
<div class="stars-layer" id="starsLayer"></div>

<div class="login-layout">

    <!-- GIRL LEFT SIDE -->
    <div class="girl-side">
        <div class="bubble" id="bubble"><span id="bubText">Unlock your journey! 🔓</span></div>
        <div class="girl-wrap" onclick="girlClick(event)">
            <svg class="girl-svg" viewBox="0 0 160 260" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <radialGradient id="irisL2" cx="36%" cy="30%" r="64%">
                        <stop offset="0%" stop-color="#b090ff" />
                        <stop offset="60%" stop-color="#5030c8" />
                        <stop offset="100%" stop-color="#200a80" />
                    </radialGradient>
                    <radialGradient id="irisR2" cx="36%" cy="30%" r="64%">
                        <stop offset="0%" stop-color="#b090ff" />
                        <stop offset="60%" stop-color="#5030c8" />
                        <stop offset="100%" stop-color="#200a80" />
                    </radialGradient>
                </defs>

                <ellipse cx="80" cy="254" rx="34" ry="6" fill="rgba(0,0,0,0.18)" />
                <rect x="58" y="210" width="16" height="36" rx="8" fill="#5a4de0" />
                <rect x="86" y="210" width="16" height="36" rx="8" fill="#5a4de0" />
                <ellipse cx="66" cy="246" rx="12" ry="7" fill="#1e1550" />
                <ellipse cx="94" cy="246" rx="12" ry="7" fill="#1e1550" />
                <path d="M46 140 Q38 172 35 215 Q38 220 44 220 L116 220 Q122 220 125 215 Q122 172 114 140 Z" fill="#7c6ef5" />
                <path d="M54 148 Q51 178 49 208" stroke="#a89ef8" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.45" />
                <path d="M62 140 L80 158 L98 140" fill="#f4c0d1" stroke="#e090b5" stroke-width="1" />
                <path d="M48 148 Q28 162 26 186 Q30 192 36 188 Q40 168 52 156 Z" fill="#fde8d8" stroke="#f0c4a8" stroke-width="0.8" />
                <g class="arm-r">
                    <path d="M108 148 Q128 136 142 120 Q146 115 142 112 Q137 110 134 115 Q122 130 106 144 Z" fill="#fde8d8" stroke="#f0c4a8" stroke-width="0.8" />
                    <circle cx="142" cy="112" r="7" fill="#fde8d8" stroke="#f0c4a8" stroke-width="0.8" />
                </g>
                <rect x="72" y="118" width="16" height="24" rx="8" fill="#fde8d8" stroke="#f0c4a8" stroke-width="0.5" />
                <ellipse cx="80" cy="90" rx="38" ry="38" fill="#fde8d8" stroke="#f0c4a8" stroke-width="0.8" />
                <ellipse cx="80" cy="76" rx="40" ry="34" fill="#2d1b6e" />
                <path d="M42 80 Q44 42 80 38 Q116 42 118 80 Q108 64 80 62 Q52 64 42 80 Z" fill="#3d2b8e" />
                <path d="M42 82 Q34 106 38 124 Q46 130 50 120 Q44 106 46 88 Z" fill="#2d1b6e" />
                <path d="M118 82 Q126 106 122 124 Q114 130 110 120 Q116 106 114 88 Z" fill="#2d1b6e" />
                <path class="ahoge" d="M80 40 Q86 24 90 18 Q92 13 88 11 Q84 14 82 22 Q80 30 79 40 Z" fill="#3d2b8e" />
                <ellipse cx="42" cy="92" rx="7" ry="9" fill="#fde8d8" stroke="#f0c4a8" stroke-width="0.7" />
                <ellipse cx="118" cy="92" rx="7" ry="9" fill="#fde8d8" stroke="#f0c4a8" stroke-width="0.7" />

                <!-- EYES -->
                <g id="eyesG">
                    <ellipse cx="63" cy="90" rx="10" ry="11" fill="white" />
                    <ellipse cx="63" cy="92" rx="7" ry="8" fill="url(#irisL2)" />
                    <ellipse cx="63" cy="92" rx="4" ry="5" fill="#1a0a50" />
                    <circle cx="66" cy="88" r="2.5" fill="white" />
                    <circle cx="60" cy="90" r="1.2" fill="white" opacity="0.6" />
                    <line x1="53" y1="84" x2="55" y2="81" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="57" y1="81" x2="58" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="63" y1="80" x2="63" y2="77" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="68" y1="81" x2="70" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="72" y1="84" x2="74" y2="82" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <ellipse cx="97" cy="90" rx="10" ry="11" fill="white" />
                    <ellipse cx="97" cy="92" rx="7" ry="8" fill="url(#irisR2)" />
                    <ellipse cx="97" cy="92" rx="4" ry="5" fill="#1a0a50" />
                    <circle cx="100" cy="88" r="2.5" fill="white" />
                    <circle cx="94" cy="90" r="1.2" fill="white" opacity="0.6" />
                    <line x1="87" y1="84" x2="85" y2="81" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="91" y1="81" x2="90" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="97" y1="80" x2="97" y2="77" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="102" y1="81" x2="104" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                    <line x1="106" y1="84" x2="108" y2="82" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round" />
                </g>

                <g id="browsG">
                    <path d="M53 78 Q63 73 73 77" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round" />
                    <path d="M87 77 Q97 73 107 78" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round" />
                </g>

                <ellipse cx="80" cy="102" rx="3" ry="2" fill="#f0b8a0" opacity="0.55" />

                <g id="mouthG">
                    <path d="M71 112 Q80 120 89 112" stroke="#e07090" stroke-width="2" fill="none" stroke-linecap="round" />
                </g>

                <ellipse id="blL" cx="50" cy="101" rx="10" ry="6" fill="#ffb3c8" opacity="0.4" />
                <ellipse id="blR" cx="110" cy="101" rx="10" ry="6" fill="#ffb3c8" opacity="0.4" />

                <polygon points="96,50 98,55 103,55 99,59 101,64 96,61 91,64 93,59 89,55 94,55" fill="#f5d020" stroke="#d4a800" stroke-width="0.5" />
                <text x="16" y="72" font-size="13" fill="#f5a623" class="sp sp1">✦</text>
                <text x="134" y="60" font-size="11" fill="#f56cc8" class="sp sp2">✦</text>
                <text x="8" y="152" font-size="9" fill="#6c6ef5" class="sp sp3">✧</text>
                <text x="140" y="145" font-size="10" fill="#f5a623" class="sp sp4">✦</text>
            </svg>
        </div>
    </div>

    <!-- LOGIN CARD -->
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-icon-wrap">
                <img src="~/images/rocket.png" alt="" class="header-mascot"
                     onerror="this.style.display='none';this.parentNode.innerHTML='🚀'" />
            </div>
            <div class="accent-line"></div>
            <h2 class="auth-card-title">Unlock Your Journey</h2>
            <p class="auth-card-sub">Enter your key or email below</p>
        </div>

        <div asp-validation-summary="All" class="alert-error"></div>

        @if (TempData["ResetSuccess"] != null)
        {
            <div class="alert alert-success">@TempData["ResetSuccess"]</div>
        }

        <form asp-action="Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()

            <div class="field-group">
                <div class="field-icon">🔑</div>
                <input asp-for="LoginIdentifier" class="field-input"
                       placeholder="Enter Your Key (e.g. ASP-XXXX-XXXX)"
                       onfocus="girlReact('curious')" onblur="girlReact('happy')" />
                <span asp-validation-for="LoginIdentifier" class="field-error"></span>
            </div>

            <div class="field-group">
                <div class="field-icon">🔒</div>
                <input asp-for="Password" type="password" class="field-input"
                       placeholder="Password" id="loginPassword"
                       onfocus="girlReact('shy')" onblur="girlReact('happy')" />
                <button type="button" class="eye-btn" onclick="toggleEye('loginPassword',this)">👁</button>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="field-row">
                <label class="checkbox-wrap">
                    <input asp-for="RememberMe" type="checkbox" class="checkbox" />
                    <span class="checkbox-label">Remember me</span>
                </label>
                <a asp-action="ForgotPassword" class="forgot-link"
                   onmouseenter="girlReact('curious')" onmouseleave="girlReact('happy')">
                    Forgot Password?
                </a>
            </div>

            <button type="submit" class="btn-full"
                    onmouseenter="girlReact('excited')" onmouseleave="girlReact('happy')">
                <span>Let's Go</span>
                <span class="btn-icon">🚀</span>
            </button>
        </form>

        <div class="divider"><span>OR</span></div>
        <p class="auth-switch">Don't have a key?</p>
        <a asp-action="Step1" class="btn-outline"
           onmouseenter="girlReact('excited')" onmouseleave="girlReact('happy')">
            Start Your Journey 🚀
        </a>
    </div>
</div>

@section Scripts {
    <script>
        (function(){

        /* MOUSE ORB */
        var orb=document.getElementById('mouseOrb');
        var ox=innerWidth/2,oy=innerHeight/2,cx=ox,cy=oy;
        document.addEventListener('mousemove',function(e){ox=e.clientX;oy=e.clientY;});
        (function ao(){cx+=(ox-cx)*.08;cy+=(oy-cy)*.08;orb.style.left=cx+'px';orb.style.top=cy+'px';requestAnimationFrame(ao);})();

        /* BG CANVAS */
        var cv=document.getElementById('bgCanvas'),ctx=cv.getContext('2d');
        var W,H,mx=innerWidth/2,my=innerHeight/2,tick=0;
        function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;buildGrid();}
        resize();window.addEventListener('resize',resize);
        document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;});

        var nodes=[];
        function buildGrid(){
            nodes=[];
            var cs=Math.ceil(W/78)+1,rs=Math.ceil(H/78)+1;
            for(var r=0;r<rs;r++)for(var c=0;c<cs;c++)
                nodes.push({x:c*78,y:r*78,ox:c*78,oy:r*78});
        }

        var parts=[];
        function spawnP(x,y,burst){
            var cols=['#6c6ef5','#f56cc8','#f5a623','#23e8c8','#a078f0'];
            var count=burst?10:1;
            for(var i=0;i<count;i++){
                var angle=Math.random()*Math.PI*2;
                var spd=burst?(Math.random()*4+1):(Math.random()*.5+.1);
                parts.push({
                    x:x||Math.random()*W, y:y||Math.random()*H,
                    vx:Math.cos(angle)*spd, vy:Math.sin(angle)*spd-(burst?2:0),
                    r:Math.random()*(burst?4:2)+.4,
                    color:cols[Math.floor(Math.random()*5)],
                    life:1, decay:Math.random()*(burst?.028:.008)+.003
                });
            }
            if(parts.length>200)parts.splice(0,parts.length-200);
        }

        function frame(){
            tick+=0.01;ctx.clearRect(0,0,W,H);
            var cols2=Math.ceil(W/78)+1;
            nodes.forEach(function(n){
                var dx=mx-n.ox,dy=my-n.oy,d=Math.sqrt(dx*dx+dy*dy),p=Math.max(0,1-d/200);
                n.x=n.ox+dx*p*0.2+Math.sin(tick+n.oy*0.03)*2.5;
                n.y=n.oy+dy*p*0.2+Math.cos(tick+n.ox*0.03)*2.5;
            });
            ctx.strokeStyle='rgba(108,110,245,0.08)';ctx.lineWidth=0.5;
            nodes.forEach(function(n,i){
                var c=i%cols2;
                if(c<cols2-1&&nodes[i+1]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+1].x,nodes[i+1].y);ctx.stroke();}
                if(nodes[i+cols2]){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(nodes[i+cols2].x,nodes[i+cols2].y);ctx.stroke();}
            });
            nodes.forEach(function(n){
                var dx=mx-n.x,dy=my-n.y,d=Math.sqrt(dx*dx+dy*dy);
                if(d<130){ctx.beginPath();ctx.arc(n.x,n.y,2.5,0,6.28);ctx.fillStyle='rgba(108,110,245,'+(1-d/130)*0.85+')';ctx.fill();}
            });
            if(Math.random()<.3)spawnP();
            parts.forEach(function(p){
                p.x+=p.vx;p.y+=p.vy;p.life-=p.decay;
                ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,6.28);
                ctx.fillStyle=p.color;ctx.globalAlpha=p.life*0.5;ctx.fill();
            });
            ctx.globalAlpha=1;
            parts=parts.filter(function(p){return p.life>0;});
            requestAnimationFrame(frame);
        }
        frame();

        /* STARS */
        var sl=document.getElementById('starsLayer');
        for(var i=0;i<38;i++){
            var st=document.createElement('div');st.className='fstar';
            st.textContent=['·','·','✦','✧','⭐'][i%5];
            st.style.left=(Math.random()*97)+'%';
            st.style.top=(Math.random()*95)+'%';
            st.style.animationDuration=(7+Math.random()*11)+'s';
            st.style.animationDelay=(Math.random()*7)+'s';
            st.style.fontSize=(6+Math.random()*11)+'px';
            st.style.opacity=(0.06+Math.random()*0.22);
            st.style.color=['#6c6ef5','#f56cc8','#f5a623','#23e8c8','#a078f0'][i%5];
            sl.appendChild(st);
        }

        /* MOUSE TRAIL */
        var tColors=['#6c6ef5','#f56cc8','#23e8c8','#f5a623','#a078f0'],lastT=0;
        document.addEventListener('mousemove',function(e){
            var now=Date.now();if(now-lastT<28)return;lastT=now;
            var d=document.createElement('div');d.className='mtrail';
            d.style.left=e.clientX+'px';d.style.top=e.clientY+'px';
            var col=tColors[Math.floor(Math.random()*5)];
            d.style.background=col;d.style.boxShadow='0 0 8px '+col;
            document.body.appendChild(d);
            setTimeout(function(){d.style.opacity='0';setTimeout(function(){if(d.parentNode)d.remove();},600);},40);
        });

        /* GIRL EXPRESSIONS */
        var defaultEyes=
            '<ellipse cx="63" cy="90" rx="10" ry="11" fill="white"/>'+
            '<ellipse cx="63" cy="92" rx="7" ry="8" fill="url(#irisL2)"/>'+
            '<ellipse cx="63" cy="92" rx="4" ry="5" fill="#1a0a50"/>'+
            '<circle cx="66" cy="88" r="2.5" fill="white"/>'+
            '<circle cx="60" cy="90" r="1.2" fill="white" opacity="0.6"/>'+
            '<line x1="53" y1="84" x2="55" y2="81" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="57" y1="81" x2="58" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="63" y1="80" x2="63" y2="77" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="68" y1="81" x2="70" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="72" y1="84" x2="74" y2="82" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<ellipse cx="97" cy="90" rx="10" ry="11" fill="white"/>'+
            '<ellipse cx="97" cy="92" rx="7" ry="8" fill="url(#irisR2)"/>'+
            '<ellipse cx="97" cy="92" rx="4" ry="5" fill="#1a0a50"/>'+
            '<circle cx="100" cy="88" r="2.5" fill="white"/>'+
            '<circle cx="94" cy="90" r="1.2" fill="white" opacity="0.6"/>'+
            '<line x1="87" y1="84" x2="85" y2="81" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="91" y1="81" x2="90" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="97" y1="80" x2="97" y2="77" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="102" y1="81" x2="104" y2="78" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="106" y1="84" x2="108" y2="82" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>';

        /* ✅ Password focus — eyes closed (shy) */
        var closedEyes=
            '<ellipse cx="63" cy="92" rx="10" ry="3" fill="#fde8d8"/>'+
            '<path d="M53 90 Q63 86 73 90" stroke="#2d1b6e" stroke-width="2.2" fill="none" stroke-linecap="round"/>'+
            '<ellipse cx="97" cy="92" rx="10" ry="3" fill="#fde8d8"/>'+
            '<path d="M87 90 Q97 86 107 90" stroke="#2d1b6e" stroke-width="2.2" fill="none" stroke-linecap="round"/>';

        /* Wink eyes */
        var winkEyes=
            '<ellipse cx="63" cy="90" rx="10" ry="11" fill="white"/>'+
            '<ellipse cx="63" cy="92" rx="7" ry="8" fill="url(#irisL2)"/>'+
            '<ellipse cx="63" cy="92" rx="4" ry="5" fill="#1a0a50"/>'+
            '<circle cx="66" cy="88" r="2.5" fill="white"/>'+
            '<line x1="53" y1="84" x2="55" y2="81" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="63" y1="80" x2="63" y2="77" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="72" y1="84" x2="74" y2="82" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<path d="M87 92 Q97 86 107 92" stroke="#2d1b6e" stroke-width="3" fill="none" stroke-linecap="round"/>'+
            '<line x1="87" y1="84" x2="85" y2="81" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="97" y1="80" x2="97" y2="77" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>'+
            '<line x1="106" y1="84" x2="108" y2="82" stroke="#2d1b6e" stroke-width="1.2" stroke-linecap="round"/>';

        var exprs={
            happy:{
                mouth:'<path d="M71 112 Q80 120 89 112" stroke="#e07090" stroke-width="2" fill="none" stroke-linecap="round"/>',
                brow:'<path d="M53 78 Q63 73 73 77" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/><path d="M87 77 Q97 73 107 78" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/>',
                eyes:'default', blush:.4,
                msgs:['Unlock your journey! 🔓','Welcome back! ✨','I am here for you! 😊']
            },
            excited:{
                mouth:'<path d="M69 110 Q80 122 91 110" stroke="#e07090" stroke-width="2.5" fill="#ffcce0" stroke-linecap="round"/><circle cx="80" cy="118" r="4" fill="#ffaac8"/>',
                brow:'<path d="M53 75 Q63 70 73 74" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/><path d="M87 74 Q97 70 107 75" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/>',
                eyes:'default', blush:.72,
                msgs:["Let's go! 🚀","Let's get started! 💫","Yay! Register now! ⭐"]
            },
            shy:{
                mouth:'<path d="M73 112 Q80 116 87 112" stroke="#e07090" stroke-width="1.8" fill="none" stroke-linecap="round"/>',
                brow:'<path d="M53 79 Q63 75 73 78" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/><path d="M87 78 Q97 75 107 79" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/>',
                eyes:'closed', blush:.9,
                msgs:['Keep your password safe! 😶','Shh... I will not look! 🙈','Your secret is safe! 🔒']
            },
            wink:{
                mouth:'<path d="M73 112 Q80 118 87 112" stroke="#e07090" stroke-width="2" fill="none" stroke-linecap="round"/>',
                brow:'<path d="M53 78 Q63 74 73 78" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/><path d="M87 77 Q97 73 107 77" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/>',
                eyes:'wink', blush:.55,
                msgs:['Keep your password safe! 😉','Your secret key matters! 🔑','Shh... protect your password! 🤫']
            },
            curious:{
                mouth:'<ellipse cx="80" cy="114" rx="5" ry="4" fill="#e07090"/>',
                brow:'<path d="M53 80 Q63 73 73 76" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/><path d="M87 76 Q97 73 107 80" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/>',
                eyes:'default', blush:.3,
                msgs:['Looking for your key? 🔍','Need any help? 🤔','I can help you! ✨']
            },
            blush:{
                mouth:'<path d="M73 110 Q80 115 87 110" stroke="#e07090" stroke-width="2" fill="none" stroke-linecap="round"/>',
                brow:'<path d="M55 79 Q63 75 72 79" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/><path d="M88 79 Q97 75 105 79" stroke="#3d2b8e" stroke-width="2.2" fill="none" stroke-linecap="round"/>',
                eyes:'default', blush:.92,
                msgs:['Hehe~ 🌸','Thank you! 💕','So sweet! 🌷','Aww~ 💜']
            }
        };

        var mG=document.getElementById('mouthG'),bG=document.getElementById('browsG');
        var blL=document.getElementById('blL'),blR=document.getElementById('blR');
        var eyesG=document.getElementById('eyesG');
        var bubEl=document.getElementById('bubble'),bubTxt=document.getElementById('bubText');
        var eyeResetTimer=null;

        window.girlReact=function(name){
            var e=exprs[name]||exprs.happy;
            mG.innerHTML=e.mouth;
            bG.innerHTML=e.brow;
            blL.setAttribute('opacity',e.blush);
            blR.setAttribute('opacity',e.blush);

            /* ✅ Eye change */
            clearTimeout(eyeResetTimer);
            if(e.eyes==='closed'){
                eyesG.innerHTML=closedEyes;
            } else if(e.eyes==='wink'){
                eyesG.innerHTML=winkEyes;
                eyeResetTimer=setTimeout(function(){eyesG.innerHTML=defaultEyes;},2000);
            } else {
                eyesG.innerHTML=defaultEyes;
            }

            bubTxt.textContent=e.msgs[Math.floor(Math.random()*e.msgs.length)];
            bubEl.classList.add('pop');
            setTimeout(function(){bubEl.classList.remove('pop');},320);
        };

        /* ✅ Click — sparks nikalta hai */
        var sparkEmojis=['✨','💫','⭐','🌟','✦','💕','🌸','🚀','💜','⚡'];
        window.girlClick=function(ev){
            var all=['happy','excited','blush','curious','wink'];
            girlReact(all[Math.floor(Math.random()*all.length)]);

            if(!ev)return;
            for(var i=0;i<10;i++){
                (function(idx){
                    setTimeout(function(){
                        var s=document.createElement('div');
                        s.className='ck-spark';
                        var angle=Math.random()*360;
                        var dist=30+Math.random()*80;
                        var ex=ev.clientX+Math.cos(angle*Math.PI/180)*dist;
                        var ey=ev.clientY+Math.sin(angle*Math.PI/180)*dist;
                        s.style.left=ex+'px';s.style.top=ey+'px';
                        s.textContent=sparkEmojis[Math.floor(Math.random()*sparkEmojis.length)];
                        document.body.appendChild(s);

                        /* Canvas burst bhi */
                        spawnP(ev.clientX,ev.clientY,true);

                        setTimeout(function(){if(s.parentNode)s.remove();},820);
                    },idx*50);
                })(i);
            }
        };

        /* AUTO CYCLE */
        var autoIdx=0,autoList=['happy','curious','happy','wink','happy','excited','happy','curious'];
        function autoCycle(){
            girlReact(autoList[autoIdx++%autoList.length]);
            setTimeout(autoCycle,3200+Math.random()*1500);
        }
        setTimeout(autoCycle,2000);

        /* EYE TOGGLE */
        window.toggleEye=function(id,btn){
            var inp=document.getElementById(id);
            if(inp.type==='password'){inp.type='text';btn.textContent='🙈';}
            else{inp.type='password';btn.textContent='👁';}
        };

        })();
    </script>
}