@* Views/Shared/_DashboardLayout.cshtml *@
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AspiraHub</title>
    <link rel="icon" href="~/images/favicon.ico" />
    <style>

            /* ══════════════════════════════════════════════════
                           VARIABLES
                        ══════════════════════════════════════════════════ */
            :root {
                --bg: #07071a;
                --bg2: #0d0d28;
                --bg3: #12122e;
                --card: rgba(14,14,40,0.9);
                --card2: rgba(18,18,46,0.95);
                --field: rgba(20,18,55,0.7);
                --border: rgba(108,110,245,0.15);
                --border2: rgba(108,110,245,0.28);
                --text: #e8e8ff;
                --text2: #9999cc;
                --text3: #6666aa;
                --blue: #6c6ef5;
                --blue-lt: #9090ff;
                --blue-dim: rgba(108,110,245,0.12);
                --pink: #f56cc8;
                --orange: #f5a623;
                --orange-lt: #f5c842;
                --orange-dim: rgba(245,166,35,0.12);
                --teal: #23e8c8;
                --green: #10b981;
                --red: #ef4444;
                --purple: #a78bfa;
                --shadow: 0 4px 24px rgba(0,0,0,0.4);
                --shadow-blue: 0 4px 24px rgba(108,110,245,0.15);
                --sidebar-w: 260px;
                --header-h: 68px;
                --radius: 16px;
                --transition: .3s cubic-bezier(.4,0,.2,1);
            }

            [data-theme="light"] {
                --bg: #f0f2ff;
                --bg2: #e8eaff;
                --bg3: #ffffff;
                --card: rgba(255,255,255,0.95);
                --card2: rgba(248,248,255,0.98);
                --field: rgba(240,242,255,0.8);
                --border: rgba(108,110,245,0.15);
                --border2: rgba(108,110,245,0.3);
                --text: #1a1a3a;
                --text2: #5555aa;
                --text3: #8888bb;
                --blue: #4a4cf0;
                --blue-lt: #5a5cf5;
                --blue-dim: rgba(74,76,240,0.1);
                --pink: #c93fa0;
                --orange: #d4820a;
                --orange-lt: #e09000;
                --orange-dim: rgba(212,130,10,0.1);
                --teal: #0a9a80;
                --green: #059669;
                --red: #dc2626;
                --purple: #7c3aed;
                --shadow: 0 4px 24px rgba(108,110,245,0.1);
                --shadow-blue: 0 4px 24px rgba(108,110,245,0.15);
            }

            /* ══════════════════════════════════════════════════
                           BASE
                        ══════════════════════════════════════════════════ */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            html, body {
                height: 100%;
                background: var(--bg);
                color: var(--text);
                font-family: 'Segoe UI',system-ui,sans-serif;
                overflow-x: hidden;
                transition: background var(--transition),color var(--transition);
            }

            a {
                text-decoration: none;
                color: inherit;
            }

            button {
                font-family: inherit;
            }

            ::-webkit-scrollbar {
                width: 5px;
            }

            ::-webkit-scrollbar-track {
                background: transparent;
            }

            ::-webkit-scrollbar-thumb {
                background: rgba(108,110,245,0.3);
                border-radius: 10px;
            }

            /* ══════════════════════════════════════════════════
                           LAYOUT
                        ══════════════════════════════════════════════════ */
            .dash-layout {
                display: flex;
                min-height: 100vh;
            }

            /* ══════════════════════════════════════════════════
                           SIDEBAR
                        ══════════════════════════════════════════════════ */
            .sidebar {
                position: fixed;
                left: 0;
                top: 0;
                bottom: 0;
                width: var(--sidebar-w);
                background: var(--card2);
                border-right: 1px solid var(--border);
                display: flex;
                flex-direction: column;
                z-index: 200;
                transition: transform var(--transition),background var(--transition);
                backdrop-filter: blur(20px);
            }

            /* Logo */
            .sidebar-logo {
                padding: 1.4rem 1.4rem 1rem;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                gap: 12px;
                flex-shrink: 0;
            }

            .sidebar-logo-icon {
                width: 42px;
                height: 42px;
                border-radius: 12px;
                background: linear-gradient(135deg,#10104a,#261870);
                border: 1px solid var(--border2);
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                flex-shrink: 0;
                box-shadow: 0 0 20px rgba(108,110,245,0.3);
            }

                .sidebar-logo-icon img {
                    width: 36px;
                    height: 36px;
                    object-fit: contain;
                }

            .sidebar-logo-text {
                font-size: 1.15rem;
                font-weight: 800;
                letter-spacing: -.5px;
                line-height: 1;
            }

            .sl-a {
                color: var(--blue);
            }

            .sl-h {
                color: var(--orange);
            }

            .sidebar-logo-sub {
                font-size: .68rem;
                color: var(--text3);
                margin-top: 2px;
            }

            /* User info */
            .sidebar-user {
                padding: .9rem 1.4rem;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                gap: 10px;
                flex-shrink: 0;
                background: var(--blue-dim);
            }

            .sidebar-avatar {
                width: 38px;
                height: 38px;
                border-radius: 10px;
                background: linear-gradient(135deg,var(--blue),var(--pink));
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
                font-weight: 700;
                color: #fff;
                flex-shrink: 0;
                overflow: hidden;
                border: 1.5px solid var(--border2);
            }

                .sidebar-avatar img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .sidebar-user-info {
                flex: 1;
                min-width: 0;
            }

            .sidebar-user-name {
                font-size: .85rem;
                font-weight: 700;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .sidebar-user-role {
                font-size: .68rem;
                color: var(--blue-lt);
                background: var(--blue-dim);
                border: 1px solid var(--border2);
                border-radius: 6px;
                padding: 1px 7px;
                display: inline-block;
                margin-top: 3px;
                font-weight: 600;
            }

            /* Nav */
            .sidebar-nav {
                flex: 1;
                overflow-y: auto;
                padding: .8rem 0;
            }

            .nav-section-label {
                font-size: .65rem;
                font-weight: 700;
                color: var(--text3);
                text-transform: uppercase;
                letter-spacing: 1.2px;
                padding: .5rem 1.4rem .3rem;
            }

            .nav-item {
                display: flex;
                align-items: center;
                gap: 11px;
                padding: .7rem 1.4rem;
                border-radius: 0;
                color: var(--text2);
                font-size: .875rem;
                font-weight: 500;
                cursor: pointer;
                transition: all .2s;
                position: relative;
                margin: .1rem .7rem;
                border-radius: 12px;
                border: 1px solid transparent;
            }

                .nav-item:hover {
                    background: var(--blue-dim);
                    color: var(--text);
                    border-color: var(--border);
                }

                .nav-item.active {
                    background: linear-gradient(135deg,rgba(108,110,245,0.18),rgba(245,108,200,0.08));
                    color: var(--blue-lt);
                    border-color: var(--border2);
                    font-weight: 600;
                    box-shadow: 0 2px 12px rgba(108,110,245,0.15);
                }

                    .nav-item.active::before {
                        content: '';
                        position: absolute;
                        left: 0;
                        top: 20%;
                        bottom: 20%;
                        width: 3px;
                        background: linear-gradient(180deg,var(--blue),var(--pink));
                        border-radius: 0 3px 3px 0;
                        left: -7px;
                    }

            .nav-icon {
                font-size: 1.1rem;
                flex-shrink: 0;
                width: 22px;
                text-align: center;
            }

            .nav-label {
                flex: 1;
            }

            .nav-badge {
                background: var(--red);
                color: #fff;
                font-size: .62rem;
                font-weight: 700;
                min-width: 18px;
                height: 18px;
                border-radius: 9px;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 5px;
            }

            /* Sidebar footer */
            .sidebar-footer {
                padding: .8rem .7rem;
                border-top: 1px solid var(--border);
                flex-shrink: 0;
            }

                .sidebar-footer .nav-item {
                    color: var(--red);
                    opacity: .8;
                }

                    .sidebar-footer .nav-item:hover {
                        background: rgba(239,68,68,.08);
                        border-color: rgba(239,68,68,.2);
                        opacity: 1;
                        color: var(--red);
                    }

            /* ══════════════════════════════════════════════════
                           MAIN CONTENT
                        ══════════════════════════════════════════════════ */
            .main-wrap {
                margin-left: var(--sidebar-w);
                flex: 1;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                transition: margin var(--transition);
            }

            /* Top bar */
            .topbar {
                position: sticky;
                top: 0;
                z-index: 100;
                height: var(--header-h);
                background: var(--card2);
                border-bottom: 1px solid var(--border);
                backdrop-filter: blur(20px);
                display: flex;
                align-items: center;
                padding: 0 1.6rem;
                gap: 1rem;
            }

            .topbar-title {
                font-size: 1.1rem;
                font-weight: 700;
                flex: 1;
                background: linear-gradient(135deg,var(--text),var(--blue-lt));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .topbar-actions {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            /* Theme toggle */
            .theme-btn {
                width: 36px;
                height: 36px;
                border-radius: 10px;
                background: var(--field);
                border: 1px solid var(--border);
                color: var(--text2);
                font-size: 1rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all .2s;
            }

                .theme-btn:hover {
                    background: var(--blue-dim);
                    border-color: var(--border2);
                    color: var(--text);
                }

            /* Notif btn */
            .notif-btn {
                position: relative;
                width: 36px;
                height: 36px;
                border-radius: 10px;
                background: var(--field);
                border: 1px solid var(--border);
                font-size: 1rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all .2s;
                color: var(--text2);
            }

                .notif-btn:hover {
                    background: var(--blue-dim);
                    border-color: var(--border2);
                }

            .notif-badge {
                position: absolute;
                top: -4px;
                right: -4px;
                background: var(--red);
                color: #fff;
                font-size: .6rem;
                font-weight: 700;
                min-width: 16px;
                height: 16px;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 4px;
                border: 2px solid var(--bg);
            }

            /* Notif panel */
            .notif-panel {
                position: fixed;
                top: calc(var(--header-h) + 10px);
                right: 20px;
                width: 320px;
                background: var(--card2);
                border: 1px solid var(--border2);
                border-radius: 18px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.4);
                z-index: 300;
                padding: 16px;
                display: none;
                max-height: 420px;
                overflow-y: auto;
                animation: fadeUp .2s ease;
            }

                .notif-panel.open {
                    display: block;
                }

            .notif-panel-title {
                font-weight: 700;
                margin-bottom: 12px;
                font-size: .9rem;
                color: var(--text);
            }

            .notif-empty {
                color: var(--text3);
                font-size: .83rem;
                text-align: center;
                padding: 24px;
            }

            .notif-item {
                padding: 10px 12px;
                border-radius: 12px;
                border: 1px solid var(--border);
                margin-bottom: 8px;
                background: var(--field);
                transition: all .2s;
            }

                .notif-item.unread {
                    border-color: var(--border2);
                    background: var(--blue-dim);
                }

                .notif-item:hover {
                    border-color: var(--border2);
                }

            .notif-item-title {
                font-weight: 600;
                font-size: .83rem;
            }

            .notif-item-body {
                font-size: .76rem;
                color: var(--text2);
                margin-top: 3px;
                line-height: 1.4;
            }

            .notif-item-time {
                font-size: .68rem;
                color: var(--text3);
                margin-top: 4px;
            }

            /* Page content */
            .page-content {
                flex: 1;
                padding: 1.6rem;
                max-width: 1100px;
                width: 100%;
                margin: 0 auto;
            }

            /* ══════════════════════════════════════════════════
                           DASHBOARD COMPONENTS
                        ══════════════════════════════════════════════════ */

            /* Page header */
            .page-header {
                margin-bottom: 1.4rem;
                animation: fadeUp .4s both;
            }

            .page-header-title {
                font-size: 1.5rem;
                font-weight: 800;
                background: linear-gradient(135deg,var(--text) 0%,var(--blue-lt) 60%,var(--pink) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .page-header-sub {
                font-size: .83rem;
                color: var(--text3);
                margin-top: 4px;
            }

            /* Profile card */
            .profile-card {
                background: var(--card);
                border: 1px solid var(--border2);
                border-radius: var(--radius);
                padding: 1.4rem 1.6rem;
                box-shadow: var(--shadow-blue);
                animation: fadeUp .4s .05s both;
                position: relative;
                overflow: hidden;
            }

                .profile-card::before {
                    content: '';
                    position: absolute;
                    top: -40px;
                    right: -40px;
                    width: 160px;
                    height: 160px;
                    border-radius: 50%;
                    background: radial-gradient(circle,rgba(108,110,245,0.12),transparent 70%);
                    pointer-events: none;
                }

            .profile-card-top {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 1rem;
                gap: 1rem;
            }

            .profile-card-left {
                display: flex;
                align-items: center;
                gap: 14px;
            }

            .profile-big-avatar {
                width: 56px;
                height: 56px;
                border-radius: 14px;
                background: linear-gradient(135deg,var(--blue),var(--pink));
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
                font-weight: 700;
                color: #fff;
                border: 2px solid var(--border2);
                flex-shrink: 0;
                overflow: hidden;
                box-shadow: 0 4px 16px rgba(108,110,245,0.3);
            }

                .profile-big-avatar img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .profile-card-name {
                font-size: 1.1rem;
                font-weight: 700;
            }

            .profile-card-sub {
                font-size: .78rem;
                color: var(--text2);
                margin-top: 3px;
            }

            .profile-card-prog {
                font-size: .74rem;
                color: var(--text3);
                margin-top: 2px;
            }

            .key-badge {
                background: var(--orange-dim);
                border: 1px solid rgba(245,166,35,0.3);
                border-radius: 10px;
                padding: 6px 12px;
                font-size: .74rem;
                color: var(--orange-lt);
                font-weight: 600;
                letter-spacing: .8px;
                font-family: 'Courier New',monospace;
                white-space: nowrap;
                flex-shrink: 0;
            }

            /* Progress bar */
            .progress-wrap {
                margin-top: .8rem;
            }

            .progress-label {
                display: flex;
                justify-content: space-between;
                font-size: .76rem;
                color: var(--text2);
                margin-bottom: 6px;
            }

            .progress-pct {
                font-weight: 700;
                color: var(--blue-lt);
            }

            .progress-bar {
                height: 7px;
                background: var(--field);
                border-radius: 10px;
                overflow: hidden;
                border: 1px solid var(--border);
            }

            .progress-fill {
                height: 100%;
                background: linear-gradient(90deg,var(--blue),var(--pink));
                border-radius: 10px;
                transition: width .8s cubic-bezier(.4,0,.2,1);
            }

            /* Profile chips */
            .profile-chips {
                display: flex;
                flex-wrap: wrap;
                gap: 7px;
                margin-top: .9rem;
            }

            .chip {
                background: var(--field);
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 5px 11px;
                display: flex;
                flex-direction: column;
                gap: 1px;
            }

            .chip-label {
                font-size: .6rem;
                color: var(--text3);
                text-transform: uppercase;
                letter-spacing: .5px;
            }

            .chip-val {
                font-size: .78rem;
                font-weight: 600;
                color: var(--text);
            }

            /* Quick stats grid */
            .stats-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill,minmax(130px,1fr));
                gap: 12px;
                animation: fadeUp .4s .1s both;
            }

            .stat-card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 1.2rem 1rem;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 6px;
                text-align: center;
                box-shadow: var(--shadow);
                transition: transform .2s,box-shadow .2s,border-color .2s;
                position: relative;
                overflow: hidden;
            }

                .stat-card::after {
                    content: '';
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(135deg,rgba(255,255,255,0.02),transparent);
                    pointer-events: none;
                }

                .stat-card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 28px rgba(0,0,0,0.3);
                }

            .stat-icon {
                font-size: 1.6rem;
                line-height: 1;
            }

            .stat-val {
                font-size: 1.9rem;
                font-weight: 900;
                line-height: 1;
            }

            .stat-label {
                font-size: .68rem;
                color: var(--text2);
                line-height: 1.3;
            }

            .stat-card.blue {
                border-color: rgba(108,110,245,0.3);
            }

                .stat-card.blue .stat-val {
                    color: var(--blue-lt);
                }

                .stat-card.blue:hover {
                    border-color: rgba(108,110,245,0.5);
                    box-shadow: 0 8px 28px rgba(108,110,245,0.2);
                }

            .stat-card.green {
                border-color: rgba(16,185,129,0.3);
            }

                .stat-card.green .stat-val {
                    color: #34d399;
                }

                .stat-card.green:hover {
                    border-color: rgba(16,185,129,0.5);
                    box-shadow: 0 8px 28px rgba(16,185,129,0.15);
                }

            .stat-card.orange {
                border-color: rgba(245,166,35,0.3);
            }

                .stat-card.orange .stat-val {
                    color: var(--orange-lt);
                }

                .stat-card.orange:hover {
                    border-color: rgba(245,166,35,0.5);
                    box-shadow: 0 8px 28px rgba(245,166,35,0.15);
                }

            .stat-card.purple {
                border-color: rgba(167,139,250,0.3);
            }

                .stat-card.purple .stat-val {
                    color: var(--purple);
                }

                .stat-card.purple:hover {
                    border-color: rgba(167,139,250,0.5);
                    box-shadow: 0 8px 28px rgba(167,139,250,0.15);
                }

            .stat-card.pink {
                border-color: rgba(245,108,200,0.3);
            }

                .stat-card.pink .stat-val {
                    color: var(--pink);
                }

            .stat-card.teal {
                border-color: rgba(35,232,200,0.3);
            }

                .stat-card.teal .stat-val {
                    color: var(--teal);
                }

            .stat-card.red {
                border-color: rgba(239,68,68,0.3);
            }

                .stat-card.red .stat-val {
                    color: #f87171;
                }

            /* Section block */
            .section-block {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 1.4rem 1.6rem;
                box-shadow: var(--shadow);
                animation: fadeUp .4s both;
            }

            .section-title {
                font-size: .95rem;
                font-weight: 700;
                margin-bottom: 1rem;
                display: flex;
                align-items: center;
                gap: 10px;
                color: var(--text);
            }

            .section-title-bar {
                width: 3px;
                height: 18px;
                background: linear-gradient(180deg,var(--blue),var(--pink));
                border-radius: 2px;
                flex-shrink: 0;
            }

            .section-header-row {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 1rem;
            }

                .section-header-row .section-title {
                    margin-bottom: 0;
                }

            /* Tool cards */
            .tools-grid {
                display: grid;
                grid-template-columns: repeat(3,1fr);
                gap: 10px;
            }

            .tool-card {
                background: var(--field);
                border: 1px solid var(--border);
                border-radius: 14px;
                padding: 1.1rem .8rem;
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 8px;
                transition: all .2s;
                cursor: pointer;
                position: relative;
                overflow: hidden;
            }

                .tool-card::before {
                    content: '';
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(135deg,rgba(108,110,245,0.06),transparent);
                    opacity: 0;
                    transition: opacity .2s;
                }

                .tool-card:hover {
                    border-color: var(--border2);
                    transform: translateY(-3px);
                    box-shadow: 0 6px 20px rgba(108,110,245,0.15);
                }

                    .tool-card:hover::before {
                        opacity: 1;
                    }

            .tool-icon {
                font-size: 1.6rem;
                line-height: 1;
            }

            .tool-name {
                font-size: .72rem;
                font-weight: 600;
                color: var(--text2);
                line-height: 1.3;
            }

            /* Job cards */
            .job-card {
                background: var(--field);
                border: 1px solid var(--border);
                border-radius: 14px;
                padding: 1rem 1.2rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
                margin-bottom: 10px;
                transition: all .2s;
            }

                .job-card:hover {
                    border-color: var(--border2);
                    transform: translateX(4px);
                    box-shadow: 0 4px 16px rgba(108,110,245,0.12);
                }

            .job-title {
                font-weight: 700;
                font-size: .9rem;
            }

            .job-company {
                font-size: .78rem;
                color: var(--blue-lt);
                margin-top: 2px;
            }

            .job-meta {
                display: flex;
                gap: 8px;
                flex-wrap: wrap;
                font-size: .72rem;
                color: var(--text2);
                margin-top: 5px;
            }

            .job-card-right {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 5px;
                flex-shrink: 0;
            }

            .match-score {
                font-size: 1.3rem;
                font-weight: 900;
            }

                .match-score.high {
                    color: #34d399;
                }

                .match-score.mid {
                    color: var(--orange-lt);
                }

                .match-score.low {
                    color: #f87171;
                }

            .match-label {
                font-size: .65rem;
                color: var(--text3);
            }

            .btn-apply {
                padding: 5px 14px;
                background: linear-gradient(135deg,var(--blue),var(--pink));
                color: #fff;
                border-radius: 20px;
                font-size: .73rem;
                font-weight: 700;
                transition: all .2s;
            }

                .btn-apply:hover {
                    transform: scale(1.05);
                    box-shadow: 0 4px 12px rgba(108,110,245,0.4);
                }

            /* Announcement */
            .announcement-card {
                background: var(--field);
                border: 1px solid var(--border);
                border-left: 3px solid var(--blue);
                border-radius: 12px;
                padding: 1rem 1.2rem;
                margin-bottom: 10px;
                transition: all .2s;
            }

                .announcement-card:hover {
                    border-color: var(--border2);
                }

            .ann-title {
                font-weight: 700;
                font-size: .88rem;
            }

            .ann-content {
                font-size: .8rem;
                color: var(--text2);
                margin-top: 5px;
                line-height: 1.5;
            }

            .ann-date {
                font-size: .68rem;
                color: var(--text3);
                margin-top: 6px;
            }

            /* Roadmap */
            .roadmap-card {
                background: var(--field);
                border: 1px solid var(--border);
                border-radius: 14px;
                padding: 1.2rem 1.4rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
            }

            .roadmap-info {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .roadmap-emoji {
                font-size: 2rem;
            }

            .roadmap-title {
                font-weight: 700;
                font-size: .9rem;
            }

            .roadmap-sub {
                font-size: .75rem;
                color: var(--text2);
                margin-top: 2px;
            }

            .roadmap-pct {
                font-size: 2.2rem;
                font-weight: 900;
                color: var(--blue-lt);
            }

            /* Badges */
            .badge {
                padding: 3px 10px;
                border-radius: 20px;
                font-size: .7rem;
                font-weight: 600;
                display: inline-block;
            }

            .badge-active {
                background: rgba(16,185,129,.12);
                color: #34d399;
                border: 1px solid rgba(16,185,129,.25);
            }

            .badge-closed {
                background: rgba(239,68,68,.1);
                color: #f87171;
                border: 1px solid rgba(239,68,68,.25);
            }

            .badge-pending {
                background: var(--orange-dim);
                color: var(--orange-lt);
                border: 1px solid rgba(245,166,35,.25);
            }

            .badge-blue {
                background: var(--blue-dim);
                color: var(--blue-lt);
                border: 1px solid var(--border2);
            }

            /* Buttons */
            .btn-sm {
                padding: 7px 16px;
                border-radius: 20px;
                font-size: .78rem;
                font-weight: 600;
                cursor: pointer;
                border: none;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                transition: all .2s;
                text-decoration: none;
            }

            .btn-primary {
                background: linear-gradient(135deg,var(--blue),#5050e0);
                color: #fff;
                box-shadow: 0 3px 12px rgba(108,110,245,0.35);
            }

                .btn-primary:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 18px rgba(108,110,245,0.45);
                }

            .btn-outline {
                background: transparent;
                color: var(--text2);
                border: 1.5px solid var(--border);
            }

                .btn-outline:hover {
                    border-color: var(--blue-lt);
                    color: var(--blue-lt);
                }

            /* Empty state */
            .empty-state {
                text-align: center;
                padding: 2rem 1rem;
                color: var(--text3);
            }

            .empty-icon {
                font-size: 2.5rem;
                margin-bottom: .7rem;
            }

            .empty-state p {
                font-size: .83rem;
            }

            /* Tables */
            .table-wrap {
                overflow-x: auto;
            }

            table.dash-table {
                width: 100%;
                border-collapse: collapse;
                font-size: .82rem;
            }

            .dash-table th {
                text-align: left;
                padding: 9px 12px;
                background: var(--field);
                color: var(--text2);
                font-weight: 600;
                border-bottom: 1px solid var(--border);
            }

            .dash-table td {
                padding: 9px 12px;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .dash-table tr:last-child td {
                border-bottom: none;
            }

            .dash-table tr:hover td {
                background: var(--field);
            }

            /* Dashboard page gap */
            .dashboard-page {
                display: flex;
                flex-direction: column;
                gap: 16px;
            }

            /* Logout link style in sidebar */
            .nav-item.logout {
                color: rgba(239,68,68,0.8);
            }

                .nav-item.logout:hover {
                    background: rgba(239,68,68,0.08);
                    border-color: rgba(239,68,68,0.2);
                    color: var(--red);
                }

            /* Sidebar mobile toggle */
            .sidebar-toggle {
                display: none;
                width: 36px;
                height: 36px;
                border-radius: 10px;
                background: var(--field);
                border: 1px solid var(--border);
                font-size: 1.1rem;
                cursor: pointer;
                align-items: center;
                justify-content: center;
                color: var(--text2);
            }

            /* Animations */
            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(14px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes slideIn {
                from {
                    opacity: 0;
                    transform: translateX(-10px);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            /* Responsive */
            @@media(max-width:900px) {
                :root {
                    --sidebar-w: 220px;
                }

                .tools-grid {
                    grid-template-columns: repeat(2,1fr);
                }
            }

            @@media(max-width:700px) {
                .sidebar {
                    transform: translateX(-100%);
                }

                    .sidebar.open {
                        transform: translateX(0);
                    }

                .main-wrap {
                    margin-left: 0;
                }

                .sidebar-toggle {
                    display: flex;
                }

                .page-content {
                    padding: 1rem;
                }

                .stats-grid {
                    grid-template-columns: repeat(2,1fr);
                }

                .tools-grid {
                    grid-template-columns: repeat(2,1fr);
                }
            }
    </style>
</head>
<body>

    <div class="dash-layout">

        <!-- ══ SIDEBAR ══════════════════════════════ -->
        <aside class="sidebar" id="sidebar">

            <!-- Logo -->
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon">
                    <img src="~/images/logo.png" alt="AspiraHub"
                         onerror="this.parentNode.innerHTML='<span style=\'font-size:1.2rem;font-weight:900;color:#6c6ef5\'>A</span>'" />
                </div>
                <div>
                    <div class="sidebar-logo-text">
                        <span class="sl-a">Aspira</span><span class="sl-h">Hub</span>
                    </div>
                    <div class="sidebar-logo-sub">Career Intelligence Platform</div>
                </div>
            </div>

            <!-- User -->
            <div class="sidebar-user">
                <div class="sidebar-avatar" id="sidebarAvatar">
                    @{
                        var role = Context.Session.GetString("Role") ?? "Student";
                        var uname = Context.Session.GetString("Username") ?? "User";
                        var ukey = Context.Session.GetString("UniqueKey") ?? "";
                    }
                    <span>@uname.Substring(0, 1).ToUpper()</span>
                </div>
                <div class="sidebar-user-info">
                    <div class="sidebar-user-name">@uname</div>
                    <span class="sidebar-user-role">@role</span>
                </div>
            </div>

            <!-- Nav -->
            <nav class="sidebar-nav">
                @if (role == "Student")
                {
                    <div class="nav-section-label">Main</div>
                    <a href="#" class="nav-item active">
                        <span class="nav-icon">🏠</span>
                        <span class="nav-label">Dashboard</span>
                    </a>
                    <div class="nav-section-label">Career</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🧠</span>
                        <span class="nav-label">AI Counselor</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🔭</span>
                        <span class="nav-label">Explore Careers</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🗺️</span>
                        <span class="nav-label">Roadmap</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">📊</span>
                        <span class="nav-label">Skill Gap Analysis</span>
                    </a>
                    <div class="nav-section-label">Jobs</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">💼</span>
                        <span class="nav-label">Browse Jobs</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">📋</span>
                        <span class="nav-label">My Applications</span>
                    </a>
                    <div class="nav-section-label">Learning</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🎓</span>
                        <span class="nav-label">Courses</span>
                    </a>
                    <div class="nav-section-label">Account</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">👤</span>
                        <span class="nav-label">Profile</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🔔</span>
                        <span class="nav-label">Notifications</span>
                    </a>
                }
                else if (role == "Company")
                {
                    <div class="nav-section-label">Main</div>
                    <a href="#" class="nav-item active">
                        <span class="nav-icon">🏠</span>
                        <span class="nav-label">Dashboard</span>
                    </a>
                    <div class="nav-section-label">Jobs</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">💼</span>
                        <span class="nav-label">My Job Posts</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">➕</span>
                        <span class="nav-label">Post a Job</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">📋</span>
                        <span class="nav-label">Applications</span>
                    </a>
                    <div class="nav-section-label">Account</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🏢</span>
                        <span class="nav-label">Company Profile</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🔔</span>
                        <span class="nav-label">Notifications</span>
                    </a>
                }
                else if (role == "Admin")
                {
                    <div class="nav-section-label">Main</div>
                    <a href="#" class="nav-item active">
                        <span class="nav-icon">🏠</span>
                        <span class="nav-label">Dashboard</span>
                    </a>
                    <div class="nav-section-label">Manage</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">👥</span>
                        <span class="nav-label">Users</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">💼</span>
                        <span class="nav-label">Jobs</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">🗺️</span>
                        <span class="nav-label">Careers & Roadmaps</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">📢</span>
                        <span class="nav-label">Announcements</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">📊</span>
                        <span class="nav-label">Analytics</span>
                    </a>
                    <div class="nav-section-label">System</div>
                    <a href="#" class="nav-item">
                        <span class="nav-icon">📝</span>
                        <span class="nav-label">Admin Logs</span>
                    </a>
                }
            </nav>

            <!-- Logout -->
            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Logout" class="nav-item logout">
                    <span class="nav-icon">🚪</span>
                    <span class="nav-label">Sign Out</span>
                </a>
            </div>

        </aside>

        <!-- ══ MAIN ══════════════════════════════════ -->
        <div class="main-wrap">

            <!-- Topbar -->
            <header class="topbar">
                <button class="sidebar-toggle" onclick="toggleSidebar()" id="sidebarToggle">☰</button>
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-actions">
                    <button class="theme-btn" onclick="toggleTheme()" id="themeBtn" title="Toggle theme">☀️</button>
                    <button class="notif-btn" onclick="toggleNotif()" id="notifBtn">
                        🔔
                        <span class="notif-badge" id="notifCount" style="display:none">0</span>
                    </button>
                </div>
            </header>

            <!-- Notification Panel -->
            <div class="notif-panel" id="notifPanel">
                <div class="notif-panel-title">🔔 Notifications</div>
                <div id="notifContent">
                    <p class="notif-empty">Loading...</p>
                </div>
            </div>

            <!-- Page Content -->
            <main class="page-content">
                @RenderBody()
            </main>

        </div>
    </div>

    <!-- Sidebar overlay for mobile -->
    <div id="sidebarOverlay" onclick="toggleSidebar()"
         style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:150;"></div>

    @RenderSection("Scripts", required: false)

    <script>
            /* THEME */
            var isDark = true;
            function toggleTheme() {
                isDark = !isDark;
                document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
                document.getElementById('themeBtn').textContent = isDark ? '☀️' : '🌙';
                localStorage.setItem('ah-theme', isDark ? 'dark' : 'light');
            }
            (function(){
                var saved = localStorage.getItem('ah-theme');
                if (saved === 'light') { isDark = false; document.documentElement.setAttribute('data-theme','light'); document.getElementById('themeBtn').textContent = '🌙'; }
            })();

            /* SIDEBAR MOBILE */
            function toggleSidebar() {
                var sb = document.getElementById('sidebar');
                var ov = document.getElementById('sidebarOverlay');
                sb.classList.toggle('open');
                ov.style.display = sb.classList.contains('open') ? 'block' : 'none';
            }

            /* NOTIF PANEL */
            function toggleNotif() {
                document.getElementById('notifPanel').classList.toggle('open');
            }
            document.addEventListener('click', function(e) {
                var panel = document.getElementById('notifPanel');
                if (!e.target.closest('#notifBtn') && !e.target.closest('#notifPanel'))
                    panel.classList.remove('open');
            });

            /* NAV ACTIVE */
            document.querySelectorAll('.nav-item').forEach(function(item) {
                item.addEventListener('click', function() {
                    document.querySelectorAll('.nav-item').forEach(function(i){ i.classList.remove('active'); });
                    this.classList.add('active');
                });
            });
    </script>

</body>
</html>